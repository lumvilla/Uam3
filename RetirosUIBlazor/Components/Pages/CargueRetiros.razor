@page "/cargue-retiros"
@using Data.Interfaces.CapaApp.ICargueInsumosRetiros
@using Data.Interfaces.CapaApp.InsertExcelBD
@using Data.Interfaces.CapaApp.Uam3.IDataInsumosRobot
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@using System.Linq
@using Shared.CapaAplicacion.DA
@using Shared.CapaAplicacion.Vinculados
@using Shared.CapaAplicacion.Terceros
@inject IRetirosInsumos InsumosRetiroService
@inject IDatosExcelRepository DatosExcelService
@inject IDataInsumosRobot DatosRepo
@inject NotificationService NotificationService
@inject IHostEnvironment HostEnvironment

<PageTitle>Cargue de Insumos Retiros</PageTitle>

<style>
    .cr-page-title {
        font-size: 22px;
        font-weight: 800;
        color: #e2e8f0;
        margin-bottom: 4px;
    }

    .cr-breadcrumb {
        font-size: 12px;
        color: #6b7280;
        margin-bottom: 24px;
    }

    /* STAT CARDS */
    .cr-stats {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .cr-stat {
        background: #1a1d27;
        border: 1px solid #2d3148;
        border-radius: 12px;
        padding: 20px;
        position: relative;
        overflow: hidden;
    }

        .cr-stat::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
        }

        .cr-stat.green::before {
            background: linear-gradient(90deg,#22c55e,#16a34a);
        }

        .cr-stat.blue::before {
            background: linear-gradient(90deg,#6366f1,#8b5cf6);
        }

        .cr-stat.orange::before {
            background: linear-gradient(90deg,#f59e0b,#d97706);
        }

    .cr-stat-hdr {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .cr-stat-label {
        font-size: 11px;
        color: #6b7280;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .cr-stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

        .cr-stat-icon.green {
            background: rgba(34,197,94,.15);
        }

        .cr-stat-icon.blue {
            background: rgba(99,102,241,.15);
        }

        .cr-stat-icon.orange {
            background: rgba(245,158,11,.15);
        }

    .cr-stat-value {
        font-size: 30px;
        font-weight: 800;
        color: #fff;
        line-height: 1;
        margin-bottom: 8px;
    }

    .cr-stat-sub {
        font-size: 12px;
        color: #6b7280;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .cr-ok {
        color: #22c55e;
        font-weight: 600;
    }

    .cr-warn {
        color: #f59e0b;
        font-weight: 600;
    }

    /* TABS */
    .cr-tabs {
        display: flex;
        gap: 4px;
        background: #1a1d27;
        border: 1px solid #2d3148;
        border-radius: 10px;
        padding: 4px;
        margin-bottom: 20px;
    }

    .cr-tab {
        padding: 9px 20px;
        border-radius: 7px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all .2s;
        user-select: none;
    }

        .cr-tab:hover:not(.cr-active) {
            background: #252840;
            color: #e2e8f0;
        }

        .cr-tab.cr-active {
            background: linear-gradient(135deg,#6366f1,#8b5cf6);
            color: #fff;
            font-weight: 600;
        }

    .cr-tc {
        font-size: 11px;
        padding: 2px 8px;
        border-radius: 10px;
        font-weight: 700;
    }

    .cr-tab.cr-active .cr-tc {
        background: rgba(255,255,255,.25);
        color: #fff;
    }

    .cr-tab:not(.cr-active) .cr-tc {
        background: #252840;
        color: #9ca3af;
    }

    .cr-tc.zero {
        background: rgba(239,68,68,.2) !important;
        color: #ef4444 !important;
    }

    /* UPLOAD */
    .cr-upload {
        border: 2px dashed #2d3148;
        border-radius: 12px;
        padding: 28px 24px;
        text-align: center;
        background: #13151f;
        margin-bottom: 20px;
        transition: all .2s;
    }

        .cr-upload:hover {
            border-color: #6366f1;
            background: rgba(99,102,241,.05);
        }

    .cr-upload-icon {
        font-size: 34px;
        margin-bottom: 10px;
    }

    .cr-upload-title {
        font-size: 15px;
        font-weight: 600;
        color: #e2e8f0;
        margin-bottom: 5px;
    }

    .cr-upload-sub {
        font-size: 12px;
        color: #6b7280;
        margin-bottom: 16px;
    }

    .cr-upload-row {
        display: flex;
        align-items: center;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .cr-file-pill {
        background: rgba(99,102,241,.12);
        border: 1px solid rgba(99,102,241,.3);
        border-radius: 8px;
        padding: 8px 14px;
        font-size: 13px;
        color: #a5b4fc;
    }

    .cr-file-input {
        display: none;
    }

    .cr-file-label {
        background: #252840;
        color: #9ca3af;
        border: 1px solid #2d3148;
        padding: 9px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all .2s;
    }

        .cr-file-label:hover {
            border-color: #6366f1;
            color: #e2e8f0;
        }

    .cr-btn {
        padding: 9px 20px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all .2s;
    }

    .cr-btn-p {
        background: linear-gradient(135deg,#6366f1,#8b5cf6);
        color: #fff;
    }

        .cr-btn-p:hover:not(:disabled) {
            opacity: .88;
            transform: translateY(-1px);
        }

        .cr-btn-p:disabled {
            opacity: .4;
            cursor: not-allowed;
        }

    .cr-btn-g {
        background: #252840;
        color: #9ca3af;
        border: 1px solid #2d3148;
    }

    /* PROGRESS */
    .cr-prog {
        background: #13151f;
        border: 1px solid #2d3148;
        border-radius: 8px;
        padding: 14px 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

    .cr-spin {
        width: 20px;
        height: 20px;
        border: 2px solid #2d3148;
        border-top-color: #6366f1;
        border-radius: 50%;
        animation: spin .8s linear infinite;
        flex-shrink: 0;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* TABLE */
    .cr-tc-card {
        background: #1a1d27;
        border: 1px solid #2d3148;
        border-radius: 12px;
        overflow: hidden;
    }

    .cr-tc-hdr {
        padding: 16px 20px;
        border-bottom: 1px solid #2d3148;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }

    .cr-tc-title {
        font-size: 14px;
        font-weight: 600;
        color: #e2e8f0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .cr-badge-ok {
        background: rgba(34,197,94,.12);
        color: #22c55e;
        font-size: 12px;
        padding: 3px 12px;
        border-radius: 20px;
        font-weight: 700;
        border: 1px solid rgba(34,197,94,.2);
    }

    .cr-badge-emp {
        background: rgba(239,68,68,.12);
        color: #ef4444;
        font-size: 12px;
        padding: 3px 12px;
        border-radius: 20px;
        font-weight: 700;
        border: 1px solid rgba(239,68,68,.2);
    }

    .cr-search {
        background: #13151f;
        border: 1px solid #2d3148;
        border-radius: 8px;
        padding: 7px 12px;
        font-size: 13px;
        color: #e2e8f0;
        width: 220px;
        outline: none;
    }

        .cr-search:focus {
            border-color: #6366f1;
        }

        .cr-search::placeholder {
            color: #4b5563;
        }

    .st-on {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        background: rgba(34,197,94,.15);
        color: #22c55e;
        border: 1px solid rgba(34,197,94,.2);
    }

    .st-off {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        background: rgba(239,68,68,.15);
        color: #ef4444;
        border: 1px solid rgba(239,68,68,.2);
    }

    .st-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
        display: inline-block;
    }

    /* RADZEN DARK */
    .cr-tc-card .rz-data-grid {
        background: #13151f !important;
        border: none !important;
    }

    .cr-tc-card .rz-data-grid-header {
        background: #13151f !important;
        border-bottom: 1px solid #2d3148 !important;
    }

    .cr-tc-card .rz-column-header {
        background: #13151f !important;
        color: #6b7280 !important;
        font-size: 11px !important;
        font-weight: 600 !important;
        text-transform: uppercase !important;
        letter-spacing: .5px !important;
        border-color: #2d3148 !important;
    }

    .cr-tc-card .rz-column-header-title {
        color: #6b7280 !important;
    }

    .cr-tc-card .rz-data-row td {
        background: #1a1d27 !important;
        color: #d1d5db !important;
        border-color: #1e2035 !important;
        font-size: 13px !important;
    }

    .cr-tc-card .rz-data-row:hover td {
        background: #1e2035 !important;
    }

    .cr-tc-card .rz-grid-table, .cr-tc-card .rz-data-grid-data {
        background: #1a1d27 !important;
    }

    .cr-tc-card .rz-datatable-scrollable-wrapper, .cr-tc-card .rz-virtualscroll {
        background: #13151f !important;
    }

    .cr-tc-card .rz-paginator {
        background: #1a1d27 !important;
        border-top: 1px solid #2d3148 !important;
        color: #6b7280 !important;
    }

        .cr-tc-card .rz-paginator .rz-paginator-element {
            background: #13151f !important;
            border: 1px solid #2d3148 !important;
            color: #9ca3af !important;
            border-radius: 6px !important;
        }

        .cr-tc-card .rz-paginator .rz-state-highlight {
            background: #6366f1 !important;
            border-color: #6366f1 !important;
            color: #fff !important;
        }

    .cr-tc-card ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
    }

    .cr-tc-card ::-webkit-scrollbar-track {
        background: #13151f;
    }

    .cr-tc-card ::-webkit-scrollbar-thumb {
        background: #2d3148;
        border-radius: 3px;
    }

        .cr-tc-card ::-webkit-scrollbar-thumb:hover {
            background: #4b5563;
        }
</style>

<div class="cr-page-title">Cargue de Insumos Retiros</div>
<div class="cr-breadcrumb">UAM3 / Insumos / Retiros</div>

<!-- STAT CARDS -->
<div class="cr-stats">
    <div class="cr-stat green">
        <div class="cr-stat-hdr">
            <div class="cr-stat-label">Directorio Activo</div>
            <div class="cr-stat-icon green">🗂️</div>
        </div>
        <div class="cr-stat-value">@((directorioActivoList?.Count() ?? 0).ToString("N0"))</div>
        <div class="cr-stat-sub">
            @if (directorioActivoList?.Any() == true)
            {
                <span class="cr-ok">✓ Cargado</span>
                <span>· @ultimaCargaDA</span>
 }
            else
            {
                <span class="cr-warn">⚠ Sin cargar</span>
                <span>· Pendiente</span>
 }
        </div>
    </div>
    <div class="cr-stat blue">
        <div class="cr-stat-hdr">
            <div class="cr-stat-label">Vinculados</div>
            <div class="cr-stat-icon blue">👥</div>
        </div>
        <div class="cr-stat-value">@((retirosVinculadosList?.Count() ?? 0).ToString("N0"))</div>
        <div class="cr-stat-sub">
            @if (retirosVinculadosList?.Any() == true)
            {
                <span class="cr-ok">✓ Cargado</span>
                <span>· @ultimaCargaVinculados</span>
 }
            else
            {
                <span class="cr-warn">⚠ Sin cargar</span>
                <span>· Pendiente</span>
 }
        </div>
    </div>
    <div class="cr-stat orange">
        <div class="cr-stat-hdr">
            <div class="cr-stat-label">Terceros</div>
            <div class="cr-stat-icon orange">🔗</div>
        </div>
        <div class="cr-stat-value">@((retirosTercerosList?.Count() ?? 0).ToString("N0"))</div>
        <div class="cr-stat-sub">
            @if (retirosTercerosList?.Any() == true)
            {
                <span class="cr-ok">✓ Cargado</span>
                <span>· @ultimaCargaTerceros</span>
 }
            else
            {
                <span class="cr-warn">⚠ Sin cargar</span>
                <span>· Pendiente</span>
 }
        </div>
    </div>
</div>

<!-- TABS -->
<div class="cr-tabs">
    <div class="cr-tab @(tabActivo == 0 ? "cr-active" : "")" @onclick="@(() => CambiarTab(0))">
        🗂️ Directorio Activo
        <span class="cr-tc @(directorioActivoList?.Any() != true ? "zero" : "")">@((directorioActivoList?.Count() ?? 0).ToString("N0"))</span>
    </div>
    <div class="cr-tab @(tabActivo == 1 ? "cr-active" : "")" @onclick="@(() => CambiarTab(1))">
        👥 Vinculados
        <span class="cr-tc @(retirosVinculadosList?.Any() != true ? "zero" : "")">@((retirosVinculadosList?.Count() ?? 0).ToString("N0"))</span>
    </div>
    <div class="cr-tab @(tabActivo == 2 ? "cr-active" : "")" @onclick="@(() => CambiarTab(2))">
        🔗 Terceros
        <span class="cr-tc @(retirosTercerosList?.Any() != true ? "zero" : "")">@((retirosTercerosList?.Count() ?? 0).ToString("N0"))</span>
    </div>
    <div class="cr-tab @(tabActivo == 3 ? "cr-active" : "")" @onclick="@(() => CambiarTab(3))">
        👁️ Consolidado
        <span class="cr-tc @(consolidadoCount == 0 ? "zero" : "")">@consolidadoCount.ToString("N0")</span>
    </div>
</div>

<!-- TAB: DIRECTORIO ACTIVO -->
@if (tabActivo == 0)
{
    <div class="cr-upload">
        <div class="cr-upload-icon">📤</div>
        <div class="cr-upload-title">Cargar nuevo Directorio Activo</div>
        <div class="cr-upload-sub">Arrastra tu archivo .xlsx o .csv aquí, o haz clic para seleccionarlo</div>
        <div class="cr-upload-row">
            <InputFile id="inp-da" accept=".xlsx,.csv" class="cr-file-input" OnChange="@(e => OnFileChange(e, "DA"))" disabled="@isProcessingDA" />
            <label for="inp-da" class="cr-file-label">📁 Seleccionar archivo</label>
            @if (!string.IsNullOrEmpty(selectedFileNameDA))
            {
                <div class="cr-file-pill">📄 @selectedFileNameDA</div>
                <button class="cr-btn cr-btn-p" disabled="@(fileDA == null || isProcessingDA)" @onclick="@(() => CargarArchivo("DA"))">
                    @(isProcessingDA ? "⏳ Cargando..." : "☁️ Cargar DA")
                </button>
                <button class="cr-btn cr-btn-g" @onclick="@(() => LimpiarArchivo("DA"))">✕ Limpiar</button>
            }
            else
            {

                <button class="cr-btn cr-btn-p" disabled="true">☁️ Cargar DA</button>
            }
        </div>
    </div>
    @if (isProcessingDA)
    {
        <div class="cr-prog"><div class="cr-spin"></div><span style="font-size:13px;color:#9ca3af;">Procesando Directorio Activo, esto puede tardar...</span></div>
    }
    <div class="cr-tc-card">
        <div class="cr-tc-hdr">
            <div class="cr-tc-title">
                Datos Cargados — Directorio Activo
                @if (directorioActivoList?.Any() == true)
                {
                    <span class="cr-badge-ok">✓ @(directorioActivoList.Count().ToString("N0")) registros</span>
                }
                else
                {

                    <span class="cr-badge-emp">Sin datos</span>
                }
            </div>
            <input class="cr-search" placeholder="🔍  Buscar login, cédula, nombre..." @bind="searchDA" @bind:event="oninput" />
        </div>
        <RadzenDataGrid Data="@DaFiltrado" AllowVirtualization="true" Style="height:420px;" AllowSorting="true">
            <Columns>
                <RadzenDataGridColumn TItem="DirectorioActivo" Title="#" Width="60px" Sortable="false">
                    <Template Context="d">@(directorioActivoList!.ToList().IndexOf(d) + 1)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="DirectorioActivo" Property="@nameof(DirectorioActivo.FechaCargue)" Title="F. Cargue" Width="145px" FormatString="{0:dd/MM/yyyy HH:mm}" />
                <RadzenDataGridColumn TItem="DirectorioActivo" Property="@nameof(DirectorioActivo.Origen)" Title="Origen" Width="90px" />
                <RadzenDataGridColumn TItem="DirectorioActivo" Property="@nameof(DirectorioActivo.Login)" Title="Login" Width="140px" />
                <RadzenDataGridColumn TItem="DirectorioActivo" Property="@nameof(DirectorioActivo.Identificacion)" Title="Identificación" Width="140px" />
                <RadzenDataGridColumn TItem="DirectorioActivo" Property="@nameof(DirectorioActivo.NombreCompleto)" Title="Nombre Completo" />
                <RadzenDataGridColumn TItem="DirectorioActivo" Property="@nameof(DirectorioActivo.Estado)" Title="Estado" Width="130px">
                    <Template Context="d">
                        @if (d.Estado?.ToUpper() == "ACTIVO")
                        {
                            <span class="st-on"><span class="st-dot"></span>ACTIVO</span>
                        }
                        else
                        {

                            <span class="st-off"><span class="st-dot"></span>@(d.Estado ?? "—")</span>
                        }
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
}

<!-- TAB: VINCULADOS -->
@if (tabActivo == 1)
{
    <div class="cr-upload">
        <div class="cr-upload-icon">📤</div>
        <div class="cr-upload-title">Cargar nuevos Retiros Vinculados</div>
        <div class="cr-upload-sub">Archivo Excel de retiros Workday (.xlsx)</div>
        <div class="cr-upload-row">
            <InputFile id="inp-vin" accept=".xlsx" class="cr-file-input" OnChange="@(e => OnFileChange(e, "Vinculados"))" disabled="@isProcessingVinculados" />
            <label for="inp-vin" class="cr-file-label">📁 Seleccionar archivo</label>
            @if (!string.IsNullOrEmpty(selectedFileNameVinculados))
            {
                <div class="cr-file-pill">📄 @selectedFileNameVinculados</div>
                <button class="cr-btn cr-btn-p" disabled="@(fileVinculados == null || isProcessingVinculados)" @onclick="@(() => CargarArchivo("Vinculados"))">
                    @(isProcessingVinculados ? "⏳ Cargando..." : "☁️ Cargar Vinculados")
                </button>
                <button class="cr-btn cr-btn-g" @onclick="@(() => LimpiarArchivo("Vinculados"))">✕ Limpiar</button>
            }
            else
            {

                <button class="cr-btn cr-btn-p" disabled="true">☁️ Cargar Vinculados</button>
            }
        </div>
    </div>
    @if (isProcessingVinculados)
    {
        <div class="cr-prog"><div class="cr-spin"></div><span style="font-size:13px;color:#9ca3af;">Procesando Vinculados, esto puede tardar...</span></div>
    }
    <div class="cr-tc-card">
        <div class="cr-tc-hdr">
            <div class="cr-tc-title">
                Datos Cargados — Vinculados
                @if (retirosVinculadosList?.Any() == true)
                {
                    <span class="cr-badge-ok">✓ @(retirosVinculadosList.Count().ToString("N0")) registros</span>
                }
                else
                {

                    <span class="cr-badge-emp">Sin datos</span>
                }
            </div>
            <input class="cr-search" placeholder="🔍  Buscar nombre, cédula..." @bind="searchVin" @bind:event="oninput" />
        </div>
        <RadzenDataGrid Data="@VinFiltrado" AllowVirtualization="true" Style="height:420px;" AllowSorting="true">
            <Columns>
                <RadzenDataGridColumn TItem="Vinculados" Title="#" Width="60px" Sortable="false">
                    <Template Context="d">@(retirosVinculadosList!.ToList().IndexOf(d) + 1)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Vinculados" Property="@nameof(Vinculados.FechaCargue)" Title="F. Cargue" Width="145px" FormatString="{0:dd/MM/yyyy HH:mm}" />
                <RadzenDataGridColumn TItem="Vinculados" Property="@nameof(Vinculados.Origen)" Title="Origen" Width="90px" />
                <RadzenDataGridColumn TItem="Vinculados" Property="@nameof(Vinculados.Nombre)" Title="Nombre" />
                <RadzenDataGridColumn TItem="Vinculados" Property="@nameof(Vinculados.Cedula)" Title="Cédula" Width="140px" />
                <RadzenDataGridColumn TItem="Vinculados" Property="@nameof(Vinculados.FechaRetiro)" Title="F. Retiro" Width="140px" />
                <RadzenDataGridColumn TItem="Vinculados" Property="@nameof(Vinculados.Company)" Title="Compañía" Width="150px" />
            </Columns>
        </RadzenDataGrid>
    </div>
}

<!-- TAB: TERCEROS -->
@if (tabActivo == 2)
{
    <div class="cr-upload">
        <div class="cr-upload-icon">📤</div>
        <div class="cr-upload-title">Cargar nuevos Retiros Terceros (IAM)</div>
        <div class="cr-upload-sub">Archivo Excel de retiros de Terceros (.xlsx)</div>
        <div class="cr-upload-row">
            <InputFile id="inp-ter" accept=".xlsx" class="cr-file-input" OnChange="@(e => OnFileChange(e, "Terceros"))" disabled="@isProcessingTerceros" />
            <label for="inp-ter" class="cr-file-label">📁 Seleccionar archivo</label>
            @if (!string.IsNullOrEmpty(selectedFileNameTerceros))
            {
                <div class="cr-file-pill">📄 @selectedFileNameTerceros</div>
                <button class="cr-btn cr-btn-p" disabled="@(fileTerceros == null || isProcessingTerceros)" @onclick="@(() => CargarArchivo("Terceros"))">
                    @(isProcessingTerceros ? "⏳ Cargando..." : "☁️ Cargar Terceros")
                </button>
                <button class="cr-btn cr-btn-g" @onclick="@(() => LimpiarArchivo("Terceros"))">✕ Limpiar</button>
            }
            else
            {

                <button class="cr-btn cr-btn-p" disabled="true">☁️ Cargar Terceros</button>
            }
        </div>
    </div>
    @if (isProcessingTerceros)
    {
        <div class="cr-prog"><div class="cr-spin"></div><span style="font-size:13px;color:#9ca3af;">Procesando Terceros, esto puede tardar...</span></div>
    }
    <div class="cr-tc-card">
        <div class="cr-tc-hdr">
            <div class="cr-tc-title">
                Datos Cargados — Terceros
                @if (retirosTercerosList?.Any() == true)
                {
                    <span class="cr-badge-ok">✓ @(retirosTercerosList.Count().ToString("N0")) registros</span>
                }
                else
                {

                    <span class="cr-badge-emp">Sin datos</span>
                }
            </div>
            <input class="cr-search" placeholder="🔍  Buscar login, cédula, nombre..." @bind="searchTer" @bind:event="oninput" />
        </div>
        <RadzenDataGrid Data="@TerFiltrado" AllowVirtualization="true" Style="height:420px;" AllowSorting="true">
            <Columns>
                <RadzenDataGridColumn TItem="Shared.CapaAplicacion.Terceros.Terceros" Title="#" Width="60px" Sortable="false">
                    <Template Context="d">@(retirosTercerosList!.ToList().IndexOf(d) + 1)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Shared.CapaAplicacion.Terceros.Terceros" Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.FechaCargue)" Title="F. Cargue" Width="145px" />
                <RadzenDataGridColumn TItem="Shared.CapaAplicacion.Terceros.Terceros" Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.Origen)" Title="Origen" Width="90px" />
                <RadzenDataGridColumn TItem="Shared.CapaAplicacion.Terceros.Terceros" Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.Login)" Title="Login" Width="140px" />
                <RadzenDataGridColumn TItem="Shared.CapaAplicacion.Terceros.Terceros" Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.Cedula)" Title="Cédula" Width="140px" />
                <RadzenDataGridColumn TItem="Shared.CapaAplicacion.Terceros.Terceros" Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.NombreCompleto)" Title="Nombre Completo" />
                <RadzenDataGridColumn TItem="Shared.CapaAplicacion.Terceros.Terceros" Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.EstadoEntidad)" Title="Estado Entidad" Width="140px" />
                <RadzenDataGridColumn TItem="Shared.CapaAplicacion.Terceros.Terceros" Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.FechaRetiro)" Title="F. Retiro" Width="140px" />
            </Columns>
        </RadzenDataGrid>
    </div>
}

<!-- TAB: CONSOLIDADO -->
@if (tabActivo == 3)
{
    <div class="cr-tc-card">
        <div class="cr-tc-hdr">
            <div class="cr-tc-title">
                Vista Consolidado
                @if (consolidadoCount > 0)
                {
                    <span class="cr-badge-ok">✓ @consolidadoCount.ToString("N0") registros</span>
                }
                else
                {

                    <span class="cr-badge-emp">Sin datos</span>
                }
            </div>
            <div style="display:flex;align-items:center;gap:10px;">
                <input class="cr-search" placeholder="🔍  Buscar cédula, login, nombre..." @bind="searchCon" @bind:event="oninput" />
                <button class="cr-btn cr-btn-g" style="padding:7px 14px;font-size:12px;" disabled="@isLoadingConsolidado" @onclick="RefrescarConsolidado">
                    @if (isLoadingConsolidado)
                    {
                        <span>⏳</span>
                    }
                    else
                    {

                        <span>🔄</span>
                    }
                    Refrescar
                </button>
            </div>
        </div>
        @if (isLoadingConsolidado)
        {
            <div class="cr-prog"><div class="cr-spin"></div><span style="font-size:13px;color:#9ca3af;">Cargando consolidado...</span></div>
        }
        else
        {
            <RadzenDataGrid Data="@ConFiltrado" AllowVirtualization="true" Style="height:460px;" AllowSorting="true" Density="Density.Compact">
                <Columns>
                    <RadzenDataGridColumn TItem="dynamic" Title="Cédula" Width="130px">
                        <Template Context="d">@ObtenerValorCon(d, "cedula")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="dynamic" Title="Login" Width="140px">
                        <Template Context="d">@ObtenerValorCon(d, "login")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="dynamic" Title="Nombre">
                        <Template Context="d">@ObtenerValorCon(d, "nombre")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="dynamic" Title="Estado" Width="130px">
                        <Template Context="d">
                            @{
                                var est = ObtenerValorCon(d, "estado_entidad");
                            }
                            @if (est == "Habilitado")
                            {
                                <span class="st-on"><span class="st-dot"></span>@est</span>
                            }
                            else
                            {

                                <span class="st-off"><span class="st-dot"></span>@est</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="dynamic" Title="F. Retiro" Width="120px">
                        <Template Context="d">@ObtenerValorCon(d, "fecha_retiro")</Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }
    </div>
}

@code {
    private int tabActivo = 0;
    private string searchDA = "";
    private string searchVin = "";
    private string searchTer = "";
    private string searchCon = "";

    private bool isProcessingDA = false;
    private bool isProcessingVinculados = false;
    private bool isProcessingTerceros = false;
    private bool isLoadingConsolidado = false;

    private IBrowserFile? fileDA;
    private IBrowserFile? fileVinculados;
    private IBrowserFile? fileTerceros;

    private string? selectedFileNameDA;
    private string? selectedFileNameVinculados;
    private string? selectedFileNameTerceros;

    private IEnumerable<DirectorioActivo>? directorioActivoList;
    private IEnumerable<Vinculados>? retirosVinculadosList;
    private IEnumerable<Shared.CapaAplicacion.Terceros.Terceros>? retirosTercerosList;
    private IEnumerable<dynamic>? consolidadoList;
    private int consolidadoCount = 0;

    private string ultimaCargaDA = "";
    private string ultimaCargaVinculados = "";
    private string ultimaCargaTerceros = "";

    private IEnumerable<DirectorioActivo>? DaFiltrado => string.IsNullOrWhiteSpace(searchDA)
        ? directorioActivoList
        : directorioActivoList?.Where(x =>
            (x.Login?.Contains(searchDA, StringComparison.OrdinalIgnoreCase) == true) ||
            (x.Identificacion?.Contains(searchDA, StringComparison.OrdinalIgnoreCase) == true) ||
            (x.NombreCompleto?.Contains(searchDA, StringComparison.OrdinalIgnoreCase) == true));

    private IEnumerable<Vinculados>? VinFiltrado => string.IsNullOrWhiteSpace(searchVin)
        ? retirosVinculadosList
        : retirosVinculadosList?.Where(x =>
            (x.Nombre?.Contains(searchVin, StringComparison.OrdinalIgnoreCase) == true) ||
            (x.Cedula?.Contains(searchVin, StringComparison.OrdinalIgnoreCase) == true));

    private IEnumerable<Shared.CapaAplicacion.Terceros.Terceros>? TerFiltrado => string.IsNullOrWhiteSpace(searchTer)
        ? retirosTercerosList
        : retirosTercerosList?.Where(x =>
            (x.Login?.Contains(searchTer, StringComparison.OrdinalIgnoreCase) == true) ||
            (x.Cedula?.Contains(searchTer, StringComparison.OrdinalIgnoreCase) == true) ||
            (x.NombreCompleto?.Contains(searchTer, StringComparison.OrdinalIgnoreCase) == true));

    private IEnumerable<dynamic>? ConFiltrado => string.IsNullOrWhiteSpace(searchCon)
        ? consolidadoList
        : consolidadoList?.Where(x =>
        {
            var d = (IDictionary<string, object>)x;
            bool Match(string k) => d.TryGetValue(k, out var v) && v?.ToString()?.Contains(searchCon, StringComparison.OrdinalIgnoreCase) == true;
            return Match("cedula") || Match("login") || Match("nombre") || Match("estado_entidad");
        });

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync("DA");
        await LoadDataAsync("Vinculados");
        await LoadDataAsync("Terceros");
    }

    private async Task CambiarTab(int index)
    {
        tabActivo = index;
        searchDA = searchVin = searchTer = searchCon = "";
        if (index == 3 && consolidadoList == null)
            await CargarConsolidado();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefrescarConsolidado()
    {
        consolidadoList = null;
        await CargarConsolidado();
    }

    private async Task CargarConsolidado()
    {
        isLoadingConsolidado = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await Task.Run(() =>
            {
                var r = DatosRepo.ObtenerDatosPaginados("consolidado", 0, 5000, null, null);
                consolidadoList = r.Datos.ToList();
                consolidadoCount = r.TotalRegistros;
            });
        }
        catch { consolidadoCount = 0; consolidadoList = new List<dynamic>(); }
        isLoadingConsolidado = false;
        await InvokeAsync(StateHasChanged);
    }

    private string ObtenerValorCon(dynamic item, string key)
    {
        var dic = (IDictionary<string, object>)item;
        return dic.TryGetValue(key, out var v) && v != null ? v.ToString()! : "";
    }

    private async Task LoadDataAsync(string tipo)
    {
        await Task.Run(() =>
        {
            if (tipo == "DA")
            {
                directorioActivoList = DatosExcelService.GetDirectorioActivo();
                if (directorioActivoList?.Any() == true)
                    ultimaCargaDA = directorioActivoList.Max(x => x.FechaCargue).ToString("dd/MM/yyyy HH:mm");
            }
            else if (tipo == "Vinculados")
            {
                retirosVinculadosList = DatosExcelService.GetRetirosVinculados();
                if (retirosVinculadosList?.Any() == true)
                    ultimaCargaVinculados = retirosVinculadosList.Max(x => x.FechaCargue).ToString("dd/MM/yyyy HH:mm");
            }
            else if (tipo == "Terceros")
            {
                retirosTercerosList = DatosExcelService.GetRetirosTerceros();
                if (retirosTercerosList?.Any() == true)
                    ultimaCargaTerceros = retirosTercerosList.Max(x => x.FechaCargue).ToString("dd/MM/yyyy HH:mm");
            }
        });
        await InvokeAsync(StateHasChanged);
    }

    private void OnFileChange(InputFileChangeEventArgs e, string tipo)
    {
        var file = e.File;
        if (file == null) return;
        if (tipo == "DA") { fileDA = file; selectedFileNameDA = file.Name; }
        else if (tipo == "Vinculados") { fileVinculados = file; selectedFileNameVinculados = file.Name; }
        else if (tipo == "Terceros") { fileTerceros = file; selectedFileNameTerceros = file.Name; }
        StateHasChanged();
    }

    private void LimpiarArchivo(string tipo)
    {
        if (tipo == "DA") { fileDA = null; selectedFileNameDA = null; }
        else if (tipo == "Vinculados") { fileVinculados = null; selectedFileNameVinculados = null; }
        else if (tipo == "Terceros") { fileTerceros = null; selectedFileNameTerceros = null; }
        StateHasChanged();
    }

    private async Task CargarArchivo(string tipo)
    {
        IBrowserFile? fileToProcess = null;
        Func<Stream, string, Task>? importAction = null;
        string successMessage = "";
        string? fileName = null;

        try
        {
            if (tipo == "DA")
            {
                if (fileDA == null) return;
                isProcessingDA = true;
                fileToProcess = fileDA; fileName = selectedFileNameDA;
                importAction = async (s, n) => await InsumosRetiroService.ImportarDADesdeExcel(s, n);
                successMessage = "Directorio Activo cargado correctamente.";
            }
            else if (tipo == "Vinculados")
            {
                if (fileVinculados == null) return;
                isProcessingVinculados = true;
                fileToProcess = fileVinculados; fileName = selectedFileNameVinculados;
                importAction = async (s, n) => await InsumosRetiroService.ImportarVinculadoDesdeExcel(s, n);
                successMessage = "Retiros Vinculados cargados correctamente.";
            }
            else if (tipo == "Terceros")
            {
                if (fileTerceros == null) return;
                isProcessingTerceros = true;
                fileToProcess = fileTerceros; fileName = selectedFileNameTerceros;
                importAction = async (s, n) => await InsumosRetiroService.ImportarTerceroDesdeExcel(s, n);
                successMessage = "Retiros Terceros cargados correctamente.";
            }

            await InvokeAsync(StateHasChanged);
            await using var stream = fileToProcess!.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            await importAction!(stream, fileName!);

            await LoadDataAsync("DA");
            await LoadDataAsync("Vinculados");
            await LoadDataAsync("Terceros");

            // Invalidar consolidado para que se recargue la próxima vez
            consolidadoList = null;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Éxito",
                Detail = successMessage,
                Duration = 4000
            });
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Error al cargar",
                Detail = ex.Message,
                Duration = 6000
            });
        }
        finally
        {
            if (tipo == "DA") { isProcessingDA = false; fileDA = null; selectedFileNameDA = null; }
            else if (tipo == "Vinculados") { isProcessingVinculados = false; fileVinculados = null; selectedFileNameVinculados = null; }
            else if (tipo == "Terceros") { isProcessingTerceros = false; fileTerceros = null; selectedFileNameTerceros = null; }
            await InvokeAsync(StateHasChanged);
        }
    }
}
