@page "/cargue-retiros"
@using Data.Interfaces.CapaApp.ICargueInsumosRetiros
@using Data.Interfaces.CapaApp.InsertExcelBD
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@using System.Linq;
@using Shared.CapaAplicacion.DA
@using Shared.CapaAplicacion.Vinculados
@using Shared.CapaAplicacion.Terceros
@inject IRetirosInsumos InsumosRetiroService
@inject IDatosExcelRepository DatosExcelService
@inject NotificationService NotificationService
@inject IHostEnvironment HostEnvironment

<PageTitle>Cargue de Insumos Retiros</PageTitle>

<RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
    <RadzenText Text="Cargue de Insumos Retiros" TextStyle="TextStyle.H4" />
    <RadzenTabs TabRenderMode="TabRenderMode.Client" SelectedIndexChanged="OnTabChange">
        <Tabs>

            <RadzenTabsItem Text="Cargue Directorio Activo">
                <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                    <RadzenText Text="1. Seleccione el archivo Excel/CSV del Directorio Activo." TextStyle="TextStyle.Body1" />

                    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center">
                        <InputFile id="fileDA"
                                   accept=".xlsx,.csv"
                                   OnChange="@(e => OnFileChange(e, "DA"))"
                                   style="width: 300px;"
                                   disabled="@isProcessingDA" />

                        <RadzenButton Text="Cargar DA"
                                      Click="@(() => CargarArchivo("DA"))"
                                      IsBusy="@isProcessingDA"
                                      Disabled="@(fileDA == null || isProcessingDA)"
                                      Icon="cloud_upload"
                                      ButtonStyle="ButtonStyle.Primary" />
                    </RadzenStack>

                    @if (!string.IsNullOrEmpty(selectedFileNameDA))
                    {
                        <RadzenText Text="@($"Archivo seleccionado: {selectedFileNameDA}")" TextStyle="TextStyle.Caption" />
                    }

                    @if (isProcessingDA)
                    {
                        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center">
                            <RadzenProgressBar Value="100" Mode="ProgressBarMode.Indeterminate" Style="width:70%;" />
                            <RadzenText Text="Procesando archivo DA, esto puede tardar..." TextStyle="TextStyle.Caption" />
                        </RadzenStack>
                    }

                    <hr />

                    <RadzenText Text="Datos Cargados Directorio Activo" TextStyle="TextStyle.H6" />
                    <RadzenDataGrid Data="@directorioActivoList" AllowVirtualization="true" Style="height:400px"
                                    AllowFiltering="true" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" LogicalFilterOperator="LogicalFilterOperator.And"
                                    AllowSorting="true">
                        <Columns>
                            <RadzenDataGridColumn TItem="DirectorioActivo" Title="#" Width="100px" Sortable="false" Filterable="false">
                                <Template Context="data">
                                    @(directorioActivoList!.ToList().IndexOf(data) + 1)
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn Property="@nameof(DirectorioActivo.FechaCargue)" Title="F. Cargue" Width="150px" FormatString="{0:dd/MM/yyyy HH:mm}" />
                            <RadzenDataGridColumn Property="@nameof(DirectorioActivo.Origen)" Title="Origen" Width="100px" />
                            <RadzenDataGridColumn Property="@nameof(DirectorioActivo.Login)" Title="Login" Width="150px" />
                            <RadzenDataGridColumn Property="@nameof(DirectorioActivo.Identificacion)" Title="Identificación" Width="150px" />
                            <RadzenDataGridColumn Property="@nameof(DirectorioActivo.NombreCompleto)" Title="Nombre Completo" Width="300px" />
                            <RadzenDataGridColumn Property="@nameof(DirectorioActivo.Estado)" Title="Estado" Width="100px" />
                        </Columns>
                    </RadzenDataGrid>

                </RadzenStack>
            </RadzenTabsItem>

            <RadzenTabsItem Text="Cargue Retiros Vinculados">
                <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                    <RadzenText Text="1. Seleccione el archivo Excel de retiros de Workday." TextStyle="TextStyle.Body1" />

                    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center">
                        <InputFile id="fileVinculados"
                                   accept=".xlsx"
                                   OnChange="@(e => OnFileChange(e, "Vinculados"))"
                                   style="width: 300px;"
                                   disabled="@isProcessingVinculados" />

                        <RadzenButton Text="Cargar Vinculados"
                                      Click="@(() => CargarArchivo("Vinculados"))"
                                      IsBusy="@isProcessingVinculados"
                                      Disabled="@(fileVinculados == null || isProcessingVinculados)"
                                      Icon="cloud_upload"
                                      ButtonStyle="ButtonStyle.Primary" />
                    </RadzenStack>

                    @if (!string.IsNullOrEmpty(selectedFileNameVinculados))
                    {
                        <RadzenText Text="@($"Archivo seleccionado: {selectedFileNameVinculados}")" TextStyle="TextStyle.Caption" />
                    }

                    @if (isProcessingVinculados)
                    {
                        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center">
                            <RadzenProgressBar Value="100" Mode="ProgressBarMode.Indeterminate" Style="width:70%;" />
                            <RadzenText Text="Procesando archivo Vinculados, esto puede tardar..." TextStyle="TextStyle.Caption" />
                        </RadzenStack>
                    }

                    <hr />

                    <RadzenText Text="Datos Cargados Retiros Vinculados" TextStyle="TextStyle.H6" />
                    <RadzenDataGrid Data="@retirosVinculadosList" AllowVirtualization="true" Style="height:400px"
                                    AllowFiltering="true" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" LogicalFilterOperator="LogicalFilterOperator.And"
                                    AllowSorting="true">
                        <Columns>
                            <RadzenDataGridColumn TItem="Vinculados" Title="#" Width="80px" Sortable="false" Filterable="false">
                                <Template Context="data">
                                    @(retirosVinculadosList!.ToList().IndexOf(data) + 1)
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn Property="@nameof(Vinculados.FechaCargue)" Title="F. Cargue" Width="150px" FormatString="{0:dd/MM/yyyy HH:mm}" />
                            <RadzenDataGridColumn Property="@nameof(Vinculados.Origen)" Title="Origen" Width="100px" />
                            <RadzenDataGridColumn Property="@nameof(Vinculados.Nombre)" Title="Nombre" Width="250px" />
                            <RadzenDataGridColumn Property="@nameof(Vinculados.Cedula)" Title="Cédula" Width="150px" />
                            <RadzenDataGridColumn Property="@nameof(Vinculados.FechaRetiro)" Title="F. Retiro" Width="150px" />
                            <RadzenDataGridColumn Property="@nameof(Vinculados.Company)" Title="Compañía" Width="150px" />
                        </Columns>
                    </RadzenDataGrid>

                </RadzenStack>
            </RadzenTabsItem>

            <RadzenTabsItem Text="Cargue Retiros Terceros">
                <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                    <RadzenText Text="1. Seleccione el archivo Excel de retiros de Terceros (IAM)." TextStyle="TextStyle.Body1" />

                    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center">
                        <InputFile id="fileTerceros"
                                   accept=".xlsx"
                                   OnChange="@(e => OnFileChange(e, "Terceros"))"
                                   style="width: 300px;"
                                   disabled="@isProcessingTerceros" />

                        <RadzenButton Text="Cargar Terceros"
                                      Click="@(() => CargarArchivo("Terceros"))"
                                      IsBusy="@isProcessingTerceros"
                                      Disabled="@(fileTerceros == null || isProcessingTerceros)"
                                      Icon="cloud_upload"
                                      ButtonStyle="ButtonStyle.Primary" />
                    </RadzenStack>

                    @if (!string.IsNullOrEmpty(selectedFileNameTerceros))
                    {
                        <RadzenText Text="@($"Archivo seleccionado: {selectedFileNameTerceros}")" TextStyle="TextStyle.Caption" />
                    }

                    @if (isProcessingTerceros)
                    {
                        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center">
                            <RadzenProgressBar Value="100" Mode="ProgressBarMode.Indeterminate" Style="width:70%;" />
                            <RadzenText Text="Procesando archivo Terceros, esto puede tardar..." TextStyle="TextStyle.Caption" />
                        </RadzenStack>
                    }

                    <hr />

                    <RadzenText Text="Datos Cargados Retiros Terceros" TextStyle="TextStyle.H6" />
                    <RadzenDataGrid Data="@retirosTercerosList" AllowVirtualization="true" Style="height:400px"
                                    AllowFiltering="true" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" LogicalFilterOperator="LogicalFilterOperator.And"
                                    AllowSorting="true">
                        <Columns>
                            <RadzenDataGridColumn TItem="Shared.CapaAplicacion.Terceros.Terceros" Title="#" Width="90px" Sortable="false" Filterable="false">
                                <Template Context="data">
                                    @(retirosTercerosList!.ToList().IndexOf(data) + 1)
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.FechaCargue)" Title="F. Cargue" Width="150px"  />
                            <RadzenDataGridColumn Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.Origen)" Title="Origen" Width="100px" />
                            <RadzenDataGridColumn Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.Login)" Title="Login" Width="150px" />
                            <RadzenDataGridColumn Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.Cedula)" Title="Cédula" Width="150px" />
                            <RadzenDataGridColumn Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.NombreCompleto)" Title="Nombre Completo" Width="200px" />
                            <RadzenDataGridColumn Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.EstadoEntidad)" Title="Estado Entidad" Width="150px" />
                            <RadzenDataGridColumn Property="@nameof(Shared.CapaAplicacion.Terceros.Terceros.FechaRetiro)" Title="F. Retiro" Width="150px" />
                        </Columns>
                    </RadzenDataGrid>

                </RadzenStack>
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
</RadzenStack>

@code {
    // ... (Tu código C# se mantiene exactamente igual)
    private bool isProcessingDA = false;
    private bool isProcessingVinculados = false;
    private bool isProcessingTerceros = false;

    private IBrowserFile? fileDA;
    private IBrowserFile? fileVinculados;
    private IBrowserFile? fileTerceros;

    private string? selectedFileNameDA;
    private string? selectedFileNameVinculados;
    private string? selectedFileNameTerceros;

    private IEnumerable<DirectorioActivo>? directorioActivoList;
    private IEnumerable<Vinculados>? retirosVinculadosList;
    private IEnumerable<Shared.CapaAplicacion.Terceros.Terceros>? retirosTercerosList;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync("DA");
    }

    private async Task LoadDataAsync(string tipo)
    {
        await Task.Run(() =>
        {
            if (tipo == "DA")
            {
                directorioActivoList = DatosExcelService.GetDirectorioActivo();
            }
            else if (tipo == "Vinculados")
            {
                retirosVinculadosList = DatosExcelService.GetRetirosVinculados();
            }
            else if (tipo == "Terceros")
            {
                retirosTercerosList = DatosExcelService.GetRetirosTerceros();
            }
        });
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnTabChange(int index)
    {
        string tipo = index switch
        {
            0 => "DA",
            1 => "Vinculados",
            2 => "Terceros",
            _ => "DA"
        };

        await LoadDataAsync(tipo);
    }

    private void OnFileChange(InputFileChangeEventArgs e, string tipo)
    {
        var file = e.File;

        if (file != null)
        {
            if (tipo == "DA")
            {
                fileDA = file;
                selectedFileNameDA = file.Name;
            }
            else if (tipo == "Vinculados")
            {
                fileVinculados = file;
                selectedFileNameVinculados = file.Name;
            }
            else if (tipo == "Terceros")
            {
                fileTerceros = file;
                selectedFileNameTerceros = file.Name;
            }

            StateHasChanged();
        }
    }

    private async Task CargarArchivo(string tipo)
    {
        IBrowserFile? fileToProcess = null;
        Func<Stream, string, Task>? importAction = null;
        string successMessage = "";
        string? fileName = null;

        try
        {
            if (tipo == "DA")
            {
                if (fileDA == null) return;
                isProcessingDA = true;
                fileToProcess = fileDA;
                fileName = selectedFileNameDA;
                importAction = async (stream, name) => await Task.Run(() => InsumosRetiroService.ImportarDADesdeExcel(stream, name));
                successMessage = "Directorio Activo cargado correctamente.";
            }
            else if (tipo == "Vinculados")
            {
                if (fileVinculados == null) return;
                isProcessingVinculados = true;
                fileToProcess = fileVinculados;
                fileName = selectedFileNameVinculados;
                importAction = async (stream, name) => await Task.Run(() => InsumosRetiroService.ImportarVinculadoDesdeExcel(stream, name));
                successMessage = "Retiros Vinculados cargados correctamente.";
            }
            else if (tipo == "Terceros")
            {
                if (fileTerceros == null) return;
                isProcessingTerceros = true;
                fileToProcess = fileTerceros;
                fileName = selectedFileNameTerceros;
                importAction = async (stream, name) => await Task.Run(() => InsumosRetiroService.ImportarTerceroDesdeExcel(stream, name));
                successMessage = "Retiros Terceros cargados correctamente.";
            }

            await InvokeAsync(StateHasChanged);

            await using (var stream = fileToProcess!.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024))
            {
                await importAction!(stream, fileName!);
            }

            await LoadDataAsync(tipo);

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Éxito",
                Detail = successMessage
            });
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Error",
                Detail = $"Error al cargar {tipo}: {ex.Message}"
            });
        }
        finally
        {
            if (tipo == "DA")
            {
                isProcessingDA = false;
                fileDA = null;
                selectedFileNameDA = null;
            }
            else if (tipo == "Vinculados")
            {
                isProcessingVinculados = false;
                fileVinculados = null;
                selectedFileNameVinculados = null;
            }
            else if (tipo == "Terceros")
            {
                isProcessingTerceros = false;
                fileTerceros = null;
                selectedFileNameTerceros = null;
            }

            await InvokeAsync(StateHasChanged);
        }
    }
}