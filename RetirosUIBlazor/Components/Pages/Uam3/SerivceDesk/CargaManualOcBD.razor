@using Data.Interfaces.CapaApp.IServiceDesk
@using Shared.CapaAplicacion.UserDisable
@using Radzen
@inject IRetirosDbService RetirosDbService
@inject NotificationService NotificationService

<div>
    <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
        <RadzenText Text="Carga Manual de Órdenes de Cambio — BD" TextStyle="TextStyle.H6" />

        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
            <RadzenButton Text="@(isLoadingData ? "Cargando..." : "Cargar Datos")"
                          ButtonStyle="ButtonStyle.Primary"
                          Icon="@(isLoadingData ? "hourglass_empty" : "refresh")"
                          Click="CargarDatos" Disabled="@isLoadingData" Size="ButtonSize.Medium" />
            @if (ultimaCarga != null)
            {
                <RadzenText TextStyle="TextStyle.Caption" Text="@($"Última carga: {ultimaCarga.Value:dd/MM/yyyy HH:mm:ss}")" />
            }
            @if (hayDatos)
            {
                <RadzenText TextStyle="TextStyle.Subtitle2" Text="@($"Total: {totalRegistros}")" class="rz-color-success" />
            }
        </RadzenStack>

        @if (!hayDatos && !isLoadingData)
        {
            <RadzenAlert Severity="AlertSeverity.Info" AllowClose="false" Variant="Variant.Flat">
                No hay datos. Haga clic en "Cargar Datos" para obtener la información.
            </RadzenAlert>
        }

        @if (hayDatos)
        {
            <div class="rz-p-sm-12">
                <RadzenAccordion Multiple="true">
                    <Items>
                        @RenderAccordion("bd_siebel",    datos.GetValueOrDefault("bd_siebel"),    "BD Siebel",    "storage")
                        @RenderAccordion("bd_portal",    datos.GetValueOrDefault("bd_portal"),    "BD Portal",    "web")
                        @RenderAccordion("bd_dwh_fijo",  datos.GetValueOrDefault("bd_dwh_fijo"),  "BD DWH Fijo",  "dns")
                        @RenderAccordion("bd_dwh_movil", datos.GetValueOrDefault("bd_dwh_movil"), "BD DWH Móvil", "storage")
                        @RenderAccordion("bd_fenix",     datos.GetValueOrDefault("bd_fenix"),     "BD Fénix",     "whatshot")
                        @RenderAccordion("bd_open",      datos.GetValueOrDefault("bd_open"),      "BD Open",      "settings_input_component")
                        @RenderAccordion("bd_sap_erp",   datos.GetValueOrDefault("bd_sap_erp"),   "BD SAP ERP",   "business")
                        @RenderAccordion("bd_sap_grc",   datos.GetValueOrDefault("bd_sap_grc"),   "BD SAP GRC",   "security")
                        @RenderAccordion("bd_iam",       datos.GetValueOrDefault("bd_iam"),       "BD IAM",       "groups")
                        @RenderAccordion("bd_orion",     datos.GetValueOrDefault("bd_orion"),     "BD Orion",     "hub")
                        @RenderAccordion("bd_the",       datos.GetValueOrDefault("bd_the"),       "BD THE",       "cloud")
                        @RenderAccordion("bd_cbs",       datos.GetValueOrDefault("bd_cbs"),       "BD CBS",       "grid_view")
                        @RenderAccordion("bd_cm",        datos.GetValueOrDefault("bd_cm"),        "BD CM",        "settings")
                    </Items>
                </RadzenAccordion>
            </div>
        }
    </RadzenStack>
</div>

@code {
    private bool isLoadingData = false;
    private bool hayDatos = false;
    private DateTime? ultimaCarga;
    private int totalRegistros = 0;

    private Dictionary<string, bool> processingByApp       = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, string> selectedTipoCruce   = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, string> selectedFecha       = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, string> numeroOCManual      = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, string> estadoOCManual      = new(StringComparer.OrdinalIgnoreCase);

    private Dictionary<string, IEnumerable<RetirosUserApp>> datos = new(StringComparer.OrdinalIgnoreCase);

    private static readonly string[] _apps = {
        "bd_siebel","bd_portal","bd_dwh_fijo","bd_dwh_movil","bd_fenix","bd_open",
        "bd_sap_erp","bd_sap_grc","bd_iam","bd_orion","bd_the","bd_cbs","bd_cm"
    };

    protected override void OnInitialized()
    {
        foreach (var a in _apps)
        {
            selectedTipoCruce[a] = "AMBOS";
            processingByApp[a]   = false;
            selectedFecha[a]     = "";
            numeroOCManual[a]    = "";
            estadoOCManual[a]    = "";
            datos[a]             = Enumerable.Empty<RetirosUserApp>();
        }
    }

    private RenderFragment RenderAccordion(string app, IEnumerable<RetirosUserApp> data, string label, string icon) =>
        @<RadzenAccordionItem Text="@($"{label} - Total: {data?.Count() ?? 0}")" Icon="@icon">
            <RadzenStack Gap="0.5rem">
                @RenderSeccion(app, data)
                @RenderGrid(data)
            </RadzenStack>
        </RadzenAccordionItem>;

    private IEnumerable<string> GetFechas(string app)
    {
        var d = datos.GetValueOrDefault(app);
        if (d == null || !d.Any()) return Enumerable.Empty<string>();
        return d.Select(x => x.FechaEjecucion.ToString("yyyy-MM-dd")).Distinct().OrderByDescending(x => x).ToList();
    }

    private RenderFragment RenderSeccion(string app, IEnumerable<RetirosUserApp> data)
    {
        var fechas = GetFechas(app).ToList();
        var fechaSel = selectedFecha.GetValueOrDefault(app, "");
        var numOC   = numeroOCManual.GetValueOrDefault(app, "");
        var estOC   = estadoOCManual.GetValueOrDefault(app, "");
        var disabled = processingByApp.GetValueOrDefault(app, false) || !hayDatos ||
                       string.IsNullOrEmpty(fechaSel) || string.IsNullOrWhiteSpace(numOC) || string.IsNullOrWhiteSpace(estOC);

        return @<div style="background:#1a1d27;border:1px solid #2d3148;border-radius:8px;padding:14px;margin-bottom:12px;">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" Wrap="FlexWrap.Wrap">
                @if (fechas.Any())
                {
                    <RadzenDropDown @bind-Value="selectedFecha[app]" Data="@fechas"
                                    Placeholder="Fecha" Style="width:160px;"
                                    Change="@(() => StateHasChanged())" />
                }
                <RadzenTextBox @bind-Value="numeroOCManual[app]" Placeholder="Número OC" Style="width:200px;"
                               Change="@(() => StateHasChanged())" />
                <RadzenDropDown @bind-Value="estadoOCManual[app]"
                                Data="@(new[]{"PENDIENTE","EN_PROCESO","APROBADA","COMPLETADA","RECHAZADA"})"
                                Placeholder="Estado OC" Style="width:160px;"
                                Change="@(() => StateHasChanged())" />
                <RadzenButton Text="@(processingByApp.GetValueOrDefault(app,false) ? "Guardando..." : "Guardar OC")"
                              ButtonStyle="ButtonStyle.Success" Icon="save" Size="ButtonSize.Small"
                              Disabled="@disabled" Click="@(() => GuardarOC(app))" />
            </RadzenStack>
        </div>;
    }

    private RenderFragment RenderGrid(IEnumerable<RetirosUserApp> data) =>
        @<RadzenDataGrid Data="@(data ?? Enumerable.Empty<RetirosUserApp>())" TItem="RetirosUserApp"
                         AllowFiltering="true" AllowSorting="true" AllowPaging="true" PageSize="10"
                         Density="Density.Compact" EmptyText="No hay registros"
                         FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive">
            <Columns>
                <RadzenDataGridColumn TItem="RetirosUserApp" Property="FechaEjecucion" Title="Fecha Ejec." Width="120px" />
                <RadzenDataGridColumn TItem="RetirosUserApp" Property="CedulaConsolidado" Title="Cédula" Width="120px" />
                <RadzenDataGridColumn TItem="RetirosUserApp" Property="LoginConsolidado" Title="Login Consol." Width="140px" />
                <RadzenDataGridColumn TItem="RetirosUserApp" Property="LoginApp" Title="Login App" Width="140px" />
                <RadzenDataGridColumn TItem="RetirosUserApp" Property="NombreConsolidado" Title="Nombre" Width="180px" />
                <RadzenDataGridColumn TItem="RetirosUserApp" Property="EstadoApp" Title="Estado App" Width="140px" />
                <RadzenDataGridColumn TItem="RetirosUserApp" Property="FechaRetiro" Title="F. Retiro" Width="100px" />
                <RadzenDataGridColumn TItem="RetirosUserApp" Property="TipoCruce" Title="Cruce" Width="80px" />
                <RadzenDataGridColumn TItem="RetirosUserApp" Property="NumeroOc" Title="N° OC" Width="110px" />
                <RadzenDataGridColumn TItem="RetirosUserApp" Property="EstadoOc" Title="Estado OC" Width="110px" />
            </Columns>
        </RadzenDataGrid>;

    private async Task CargarDatos()
    {
        isLoadingData = true; StateHasChanged();
        try
        {
            var todos = await RetirosDbService.ObtenerDatosTemporalesBD();
            if (todos != null && todos.Any())
            {
                foreach (var a in _apps)
                    datos[a] = todos.Where(x => x.App?.Equals(a, StringComparison.OrdinalIgnoreCase) == true);
                totalRegistros = todos.Count();
                hayDatos = true;
                ultimaCarga = DateTime.Now;
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Cargado", Detail = $"{totalRegistros} registros.", Duration = 4000 });
            }
            else
            {
                hayDatos = false;
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Info, Summary = "Sin datos", Detail = "No hay datos temporales BD.", Duration = 3000 });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = ex.Message, Duration = 8000 });
        }
        finally { isLoadingData = false; StateHasChanged(); }
    }

    private async Task GuardarOC(string app)
    {
        processingByApp[app] = true; StateHasChanged();
        try
        {
            var ok = await RetirosDbService.GuardarOCManualBD(app, selectedFecha[app], numeroOCManual[app], estadoOCManual[app], DateTime.Now.ToString("yyyy-MM-dd"));
            if (ok)
            {
                numeroOCManual[app] = ""; estadoOCManual[app] = "";
                await CargarDatos();
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Guardado", Detail = $"OC guardada para {app}.", Duration = 4000 });
            }
            else
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Sin cambios", Detail = "No se encontraron registros.", Duration = 3000 });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = ex.Message, Duration = 8000 });
        }
        finally { processingByApp[app] = false; StateHasChanged(); }
    }
}
