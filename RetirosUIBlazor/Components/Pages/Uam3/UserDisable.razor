@code {
    private bool isProcessing = false;
    private bool dataLoaded = false;
    private DateTime? ultimoProceso;
    private Dictionary<string, bool> processingByApp = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, string> selectedTipoCruce = new(StringComparer.OrdinalIgnoreCase);

    private IEnumerable<UsuarioDisableDto> usersPortal = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersDA = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersSiebelMovil = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersSiebelFijo = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersFenix = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersOpen = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersDwhMovil = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersDwhFijo = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersSapErp = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersSapGrc = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersIam = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersCbs = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersCm = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersElk = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersPcrf = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersBigData = Enumerable.Empty<UsuarioDisableDto>();

    protected override void OnInitialized()
    {
        var apps = new[] { "portal", "da", "siebelmovil", "siebelfijo", "fenix", "open", "dwhmovil", "dwhfijo", "saperp", "sapgrc", "iam", "cbs", "cm", "elk", "pcrf", "bigdata" };
        foreach (var a in apps)
        {
            if (!selectedTipoCruce.ContainsKey(a)) selectedTipoCruce[a] = "AMBOS";
            if (!processingByApp.ContainsKey(a)) processingByApp[a] = false;
        }
    }

    private RenderFragment RenderSeccionProcesar(string app, IEnumerable<UsuarioDisableDto> data, bool tieneTipoCruce) => builder =>
    {
        int seq = 0;
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "rz-p-4");
        builder.AddAttribute(seq++, "style", "background:#1a1d27; border:1px solid #2d3148; border-radius:8px; padding:14px 16px; margin-bottom:12px;");

        builder.OpenComponent<RadzenStack>(seq++);
        builder.AddAttribute(seq++, "Orientation", Orientation.Horizontal);
        builder.AddAttribute(seq++, "AlignItems", AlignItems.Center);
        builder.AddAttribute(seq++, "Gap", "1rem");
        builder.AddAttribute(seq++, "ChildContent", (RenderFragment)((stackBuilder) =>
        {
            int s = 0;
            stackBuilder.OpenComponent<RadzenText>(s++);
            stackBuilder.AddAttribute(s++, "Text", "Seleccionar para Procesar:");
            stackBuilder.AddAttribute(s++, "TextStyle", TextStyle.Subtitle2);
            stackBuilder.AddAttribute(s++, "TagName", TagName.H6);
            stackBuilder.CloseComponent();

            if (tieneTipoCruce)
            {
                var items = new[]
                {
                    new { Key = "AMBOS", Text = "Ambos" },
                    new { Key = "LOGIN", Text = "Login" },
                    new { Key = "CEDULA", Text = "Cedula" }
                };

                stackBuilder.OpenComponent<RadzenDropDown<string>>(s++);
                stackBuilder.AddAttribute(s++, "Data", items);
                stackBuilder.AddAttribute(s++, "TextProperty", "Text");
                stackBuilder.AddAttribute(s++, "ValueProperty", "Key");
                stackBuilder.AddAttribute(s++, "Value", selectedTipoCruce.GetValueOrDefault(app, "AMBOS"));
                stackBuilder.AddAttribute(s++, "ValueChanged", EventCallback.Factory.Create<string>(this, (value) =>
                {
                    selectedTipoCruce[app] = value;
                    StateHasChanged();
                }));
                stackBuilder.AddAttribute(s++, "Placeholder", "Seleccione tipo");
                stackBuilder.AddAttribute(s++, "Style", "width:200px;");
                stackBuilder.AddAttribute(s++, "Disabled", !dataLoaded);
                stackBuilder.CloseComponent();
            }

            stackBuilder.OpenComponent<RadzenButton>(s++);
            stackBuilder.AddAttribute(s++, "Text", processingByApp.GetValueOrDefault(app, false) ? "Procesando..." : "Procesar OC");
            stackBuilder.AddAttribute(s++, "ButtonStyle", ButtonStyle.Success);
            stackBuilder.AddAttribute(s++, "Icon", processingByApp.GetValueOrDefault(app, false) ? "hourglass_empty" : "playlist_add_check");
            stackBuilder.AddAttribute(s++, "Size", ButtonSize.Small);
            stackBuilder.AddAttribute(s++, "Disabled", processingByApp.GetValueOrDefault(app, false) || !dataLoaded);
            stackBuilder.AddAttribute(s++, "Click", EventCallback.Factory.Create<MouseEventArgs>(this, async () => await ProcesarOC(app)));
            stackBuilder.CloseComponent();

            stackBuilder.OpenComponent<RadzenText>(s++);
            stackBuilder.AddAttribute(s++, "Text", "Se seleccionaran los 50 Max registros mas recientes por fecha de retiro");
            stackBuilder.AddAttribute(s++, "TextStyle", TextStyle.Caption);
            stackBuilder.AddAttribute(s++, "class", "rz-color-info-dark");
            stackBuilder.CloseComponent();

            if (!dataLoaded)
            {
                stackBuilder.OpenComponent<RadzenText>(s++);
                stackBuilder.AddAttribute(s++, "Text", "Ejecute 'Generar Usuarios Disable' para habilitar el procesamiento por aplicación.");
                stackBuilder.AddAttribute(s++, "TextStyle", TextStyle.Caption);
                stackBuilder.AddAttribute(s++, "class", "rz-color-warning");
                stackBuilder.CloseComponent();
            }
        }));
        builder.CloseComponent();
        builder.CloseElement();
    };

    private RenderFragment RenderDataGrid(IEnumerable<UsuarioDisableDto> data) => builder =>
    {
        if (data == null) data = Enumerable.Empty<UsuarioDisableDto>();

        int seq = 0;
        builder.OpenComponent<RadzenDataGrid<UsuarioDisableDto>>(seq++);
        builder.AddAttribute(seq++, "Data", data);
        builder.AddAttribute(seq++, "AllowFiltering", true);
        builder.AddAttribute(seq++, "AllowSorting", true);
        builder.AddAttribute(seq++, "AllowPaging", true);
        builder.AddAttribute(seq++, "PageSize", 10);
        builder.AddAttribute(seq++, "AllowColumnResize", true);
        builder.AddAttribute(seq++, "Density", Density.Compact);
        builder.AddAttribute(seq++, "EmptyText", "No hay registros para mostrar");
        builder.AddAttribute(seq++, "FilterCaseSensitivity", FilterCaseSensitivity.CaseInsensitive);

        builder.AddAttribute(seq++, "Columns", (RenderFragment)((columnsBuilder) =>
        {
            int c = 0;

            void AddColumn(string property, string title, string width = null, string format = null)
            {
                columnsBuilder.OpenComponent<RadzenDataGridColumn<UsuarioDisableDto>>(c++);
                columnsBuilder.AddAttribute(c++, "Property", property);
                columnsBuilder.AddAttribute(c++, "Title", title);
                if (!string.IsNullOrEmpty(width)) columnsBuilder.AddAttribute(c++, "Width", width);
                if (!string.IsNullOrEmpty(format)) columnsBuilder.AddAttribute(c++, "FormatString", format);
                columnsBuilder.AddAttribute(c++, "Filterable", true);
                columnsBuilder.AddAttribute(c++, "Sortable", true);
                columnsBuilder.CloseComponent();
            }

            AddColumn("CedulaApp", "Cédula App", "120px");
            AddColumn("CedulaConsolidado", "Cédula Consolidado", "120px");
            AddColumn("LoginApp", "Login App", "150px");
            AddColumn("LoginConsolidado", "Login Consolidado", "150px");
            AddColumn("NombreConsolidado", "Nombre", "200px");
            AddColumn("EstadoApp", "Estado App", "150px");
            AddColumn("EstadoConsolidado", "Estado Consolidado", "120px");
            AddColumn("FechaRetiro", "Fecha Retiro", "120px", "{0:dd/MM/yyyy}");
            AddColumn("TipoCruce", "Tipo Cruce", "100px");
        }));

        builder.CloseComponent();
    };

    private async Task ProcesarUsuarios()
    {
        isProcessing = true;
        StateHasChanged();
        await Task.Delay(50);

        try
        {
            usersPortal = (await UserDisableService.UsuariosPortalDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersDA = (await UserDisableService.UsuariosDADisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersSiebelMovil = (await UserDisableService.UsuariosSiebelMovilDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersSiebelFijo = (await UserDisableService.UsuariosSiebelFijoDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersFenix = (await UserDisableService.UsuariosFenixDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersOpen = (await UserDisableService.UsuariosOpenDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersDwhMovil = (await UserDisableService.UsuariosDwhMovilDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersDwhFijo = (await UserDisableService.UsuariosDwhFijoDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersSapErp = (await UserDisableService.UsuariosSapErpDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersSapGrc = (await UserDisableService.UsuariosSapGrcDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersIam = (await UserDisableService.UsuariosIamDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersCbs = (await UserDisableService.UsuariosCbsDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersCm = (await UserDisableService.UsuariosCmDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersElk = (await UserDisableService.UsuariosElkDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersPcrf = (await UserDisableService.UsuariosPcrfDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersBigData = (await UserDisableService.UsuariosBigDataDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();

            ultimoProceso = DateTime.Now;
            dataLoaded = true;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Proceso Completado",
                Detail = "Se han generado los cruces de usuarios para deshabilitar.",
                Duration = 4000
            });
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Error",
                Detail = $"Error durante el cruce: {ex.Message}",
                Duration = 8000
            });
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task ProcesarOC(string app)
    {
        if (string.IsNullOrWhiteSpace(app)) return;

        processingByApp[app] = true;
        StateHasChanged();

        try
        {
            var tipo = selectedTipoCruce.GetValueOrDefault(app, "AMBOS");
            var ok = await DisplayService.ProcesarUsuariosSeleccionados(app, tipo, 50);

            if (ok)
            {
                await RefreshAppUsers(app);
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = "Procesado",
                    Detail = $"Se procesaron los usuarios para {app} (tipo: {tipo}).",
                    Duration = 4000
                });
            }
            else
            {
                await RefreshAppUsers(app);
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Info,
                    Summary = "Sin Registros",
                    Detail = $"No se encontraron usuarios para procesar en {app} (tipo: {tipo}).",
                    Duration = 3000
                });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Error al Procesar",
                Detail = $"Error procesando {app}: {ex.Message}",
                Duration = 8000
            });
        }
        finally
        {
            processingByApp[app] = false;
            StateHasChanged();
        }
    }

