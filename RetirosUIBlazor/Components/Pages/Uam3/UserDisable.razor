                        <RadzenTabs RenderMode="TabRenderMode.Client">
                            <Tabs>
                                <RadzenTabsItem Text="Por Login">
                                    <RadzenStack Gap="0.5rem">
                                        <RadzenText TextStyle="TextStyle.Caption" Text="@($"Registros: {usersPortal?.Count(x => x.TipoCruce == "LOGIN") ?? 0}")" class="rz-color-success" />
                                        @RenderDataGrid(usersPortal?.Where(x => x.TipoCruce == "LOGIN"))
                                    </RadzenStack>
                                </RadzenTabsItem>
                                <RadzenTabsItem Text="Por Cedula">
                                    <RadzenStack Gap="0.5rem">
                                        <RadzenText TextStyle="TextStyle.Caption" Text="@($"Registros: {usersPortal?.Count(x => x.TipoCruce == "CEDULA") ?? 0}")" class="rz-color-info" />
                                        <RadzenAlert Severity="AlertSeverity.Info" AllowClose="false" Variant="Variant.Flat" Size="AlertSize.ExtraSmall">
                                            Estos usuarios coinciden por numero de documento pero su Login no coincidía o era diferente.
                                        </RadzenAlert>
                                        @RenderDataGrid(usersPortal?.Where(x => x.TipoCruce == "CEDULA"))
                                    </RadzenStack>
                                </RadzenTabsItem>
                            </Tabs>
                        </RadzenTabs>
                    </RadzenStack>
