@using Shared.CapaAplicacion.UserDisable
@using Radzen
@inject ICrucesExcel UserDisableService
@inject ICrucesDisplayService DisplayService
@inject NotificationService NotificationService

<PageTitle>Uam3 - Usuarios a Deshabilitar</PageTitle>

<style>
    /* ACCORDION DARK */
    .rz-accordion .rz-accordion-header {
        background: #1a1d27 !important;
        border: 1px solid #2d3148 !important;
        color: #fff !important;
    }

        .rz-accordion .rz-accordion-header:hover {
            background: #252840 !important;
        }

        .rz-accordion .rz-accordion-header .rz-accordion-header-text {
            color: #fff !important;
            font-weight: 600;
        }

        .rz-accordion .rz-accordion-header span {
            color: #fff !important;
        }

        .rz-accordion .rz-accordion-header a {
            color: #fff !important;
        }

        .rz-accordion .rz-accordion-header * {
            color: #fff !important;
        }

        .rz-accordion .rz-accordion-header .rz-icon {
            color: #6366f1 !important;
        }

    .rz-accordion .rz-accordion-content {
        background: #13151f !important;
        border: 1px solid #2d3148 !important;
        border-top: none !important;
    }

    /* TABS DARK */
    .rz-tabview .rz-tabview-nav {
        background: #1a1d27 !important;
        border-bottom: 1px solid #2d3148 !important;
    }

        .rz-tabview .rz-tabview-nav li a {
            color: #9ca3af !important;
        }

        .rz-tabview .rz-tabview-nav li.rz-state-active a {
            color: #6366f1 !important;
            border-bottom: 2px solid #6366f1 !important;
        }

    .rz-tabview .rz-tabview-panels {
        background: #13151f !important;
        border: 1px solid #2d3148 !important;
        border-top: none !important;
    }

    /* DATAGRID DARK */
    .rz-data-grid {
        background: #1a1d27 !important;
        border: 1px solid #2d3148 !important;
    }

    .rz-data-grid-header {
        background: #13151f !important;
        border-bottom: 1px solid #2d3148 !important;
    }

    .rz-column-header {
        background: #13151f !important;
        color: #6b7280 !important;
        font-size: 11px !important;
        font-weight: 600 !important;
        text-transform: uppercase !important;
        border-color: #2d3148 !important;
    }

    .rz-column-header-title {
        color: #6b7280 !important;
    }

    .rz-data-grid .rz-data-row {
        background: #1a1d27 !important;
        color: #fff !important;
        border-color: #1e2035 !important;
        font-size: 12px !important;
    }

    .rz-data-row:hover td {
        background: #1e2035 !important;
    }

    .rz-grid-table, .rz-data-grid-data {
        background: #1a1d27 !important;
    }

    .rz-datatable-scrollable-wrapper, .rz-virtualscroll {
        background: #13151f !important;
    }

    .rz-paginator {
        background: #1a1d27 !important;
        border-top: 1px solid #2d3148 !important;
        color: #6b7280 !important;
    }

        .rz-paginator .rz-paginator-element {
            background: #13151f !important;
            border: 1px solid #2d3148 !important;
            color: #9ca3af !important;
            border-radius: 6px !important;
        }

        .rz-paginator .rz-state-highlight {
            background: #6366f1 !important;
            border-color: #6366f1 !important;
            color: #fff !important;
        }

    /* DROPDOWN DARK */
    .rz-dropdown {
        background: #13151f !important;
        border: 1px solid #2d3148 !important;
        color: #e2e8f0 !important;
    }

        .rz-dropdown .rz-dropdown-label {
            color: #e2e8f0 !important;
        }

    .rz-dropdown-panel {
        background: #1a1d27 !important;
        border: 1px solid #2d3148 !important;
    }

    .rz-dropdown-item {
        color: #d1d5db !important;
    }

        .rz-dropdown-item:hover {
            background: #252840 !important;
        }

        .rz-dropdown-item.rz-state-highlight {
            background: #6366f1 !important;
            color: #fff !important;
        }

    /* PROCESAR SECTION */
    .ud-proc-section {
        background: #1a1d27 !important;
        border: 1px solid #2d3148;
        border-radius: 8px;
        padding: 14px 16px;
        margin-bottom: 12px;
    }

    /* TEXT OVERRIDES */
    .rz-text-caption {
        color: #9ca3af !important;
    }

    .rz-color-success {
        color: #22c55e !important;
    }

    .rz-color-info {
        color: #60a5fa !important;
    }

    .rz-color-info-dark {
        color: #818cf8 !important;
    }

    .rz-color-warning {
        color: #f59e0b !important;
    }

    /* ALERT */
    .rz-alert {
        background: rgba(99,102,241,.08) !important;
        border-color: rgba(99,102,241,.25) !important;
        color: #a5b4fc !important;
    }

    /* PROGRESS BAR */
    .rz-progressbar {
        background: #2d3148 !important;
    }

    .rz-progressbar-value {
        background: linear-gradient(90deg,#6366f1,#8b5cf6) !important;
    }

    /* PAGE TITLE */
    .rz-text-h4 {
        color: #e2e8f0 !important;
    }

    .rz-text-body1 {
        color: #9ca3af !important;
    }

    /* SCROLLBAR */
    ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
    }

    ::-webkit-scrollbar-track {
        background: #13151f;
    }

    ::-webkit-scrollbar-thumb {
        background: #2d3148;
        border-radius: 3px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: #4b5563;
        }
</style>

<RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
    <RadzenText Text="Usuarios a Deshabilitar (UAM3)" TextStyle="TextStyle.H4" />
    <RadzenText Text="Generación de reportes de usuarios a deshabilitar por aplicación." TextStyle="TextStyle.Body1" />

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
        <RadzenButton Text="@(isProcessing ? "Procesando..." : "Generar Usuarios Disable")"
                      ButtonStyle="ButtonStyle.Danger"
                      Icon="@(isProcessing ? "hourglass_empty" : "sync")"
                      Click="ProcesarUsuarios"
                      Disabled="@isProcessing"
                      Size="ButtonSize.Medium" />

        @if (ultimoProceso != null)
        {
            <RadzenText TextStyle="TextStyle.Caption" Text="@($"ultima ejecución: {ultimoProceso.Value:dd/MM/yyyy HH:mm:ss}")" />
        }
    </RadzenStack>

    @if (isProcessing)
    {
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Style="width: 300px;" />
            <RadzenText Text="Cargando datos..." TextStyle="TextStyle.Body2" />
        </RadzenStack>
    }

