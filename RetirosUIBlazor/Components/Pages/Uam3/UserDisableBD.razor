@page "/uam3/user-disable-Bd"
@using Data.Interfaces.CapaApp.IServicesCrucesExcel
@using Shared.CapaAplicacion.UserDisable
@using Radzen
@inject ICrucesExcelBD UserDisableService
@inject ICrucesDisplayServiceBD DisplayService
@inject NotificationService NotificationService

<PageTitle>Uam3 - Usuarios a Deshabilitar (BD)</PageTitle>

<style>
    .rz-accordion .rz-accordion-header { background:#1a1d27 !important; border:1px solid #2d3148 !important; color:#fff !important; }
    .rz-accordion .rz-accordion-header:hover { background:#252840 !important; }
    .rz-accordion .rz-accordion-header .rz-accordion-header-text { color:#fff !important; font-weight:600; }
    .rz-accordion .rz-accordion-header span { color:#fff !important; }
    .rz-accordion .rz-accordion-header a { color:#fff !important; }
    .rz-accordion .rz-accordion-header * { color:#fff !important; }
    .rz-accordion .rz-accordion-header .rz-icon { color:#6366f1 !important; }
    .rz-accordion .rz-accordion-content { background:#13151f !important; border:1px solid #2d3148 !important; border-top:none !important; }
    .rz-tabview .rz-tabview-nav { background:#1a1d27 !important; border-bottom:1px solid #2d3148 !important; }
    .rz-tabview .rz-tabview-nav li a { color:#9ca3af !important; }
    .rz-tabview .rz-tabview-nav li.rz-state-active a { color:#6366f1 !important; border-bottom:2px solid #6366f1 !important; }
    .rz-tabview .rz-tabview-panels { background:#13151f !important; border:1px solid #2d3148 !important; border-top:none !important; }
    .rz-data-grid { background:#1a1d27 !important; border:1px solid #2d3148 !important; }
    .rz-data-grid-header { background:#13151f !important; border-bottom:1px solid #2d3148 !important; }
    .rz-column-header { background:#13151f !important; color:#6b7280 !important; font-size:11px !important; font-weight:600 !important; text-transform:uppercase !important; border-color:#2d3148 !important; }
    .rz-column-header-title { color:#6b7280 !important; }
    .rz-data-row td { background:#1a1d27 !important; color:#d1d5db !important; border-color:#1e2035 !important; font-size:12px !important; }
    .rz-data-row:hover td { background:#1e2035 !important; }
    .rz-paginator { background:#1a1d27 !important; border-top:1px solid #2d3148 !important; color:#6b7280 !important; }
    .rz-paginator .rz-paginator-element { background:#13151f !important; border:1px solid #2d3148 !important; color:#9ca3af !important; border-radius:6px !important; }
    .rz-paginator .rz-state-highlight { background:#6366f1 !important; border-color:#6366f1 !important; color:#fff !important; }
    .rz-dropdown { background:#13151f !important; border:1px solid #2d3148 !important; color:#e2e8f0 !important; }
    .rz-dropdown .rz-dropdown-label { color:#e2e8f0 !important; }
    .rz-dropdown * { color:#e2e8f0 !important; }
    .rz-dropdown-panel { background:#1a1d27 !important; border:1px solid #2d3148 !important; }
    .rz-dropdown-item { color:#d1d5db !important; }
    .rz-dropdown-item:hover { background:#252840 !important; }
    .rz-dropdown-item.rz-state-highlight { background:#6366f1 !important; color:#fff !important; }
    .rz-alert { background:rgba(99,102,241,.08) !important; border-color:rgba(99,102,241,.25) !important; color:#a5b4fc !important; }
    .rz-text-h4 { color:#e2e8f0 !important; }
    .rz-text-body1 { color:#9ca3af !important; }
    .rz-color-success { color:#22c55e !important; }
    .rz-color-info { color:#60a5fa !important; }
    .rz-color-info-dark { color:#818cf8 !important; }
    .rz-color-warning { color:#f59e0b !important; }
</style>

<RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
    <RadzenText Text="Usuarios a Deshabilitar — Capa Base de Datos" TextStyle="TextStyle.H4" />
    <RadzenText Text="Generación de reportes de usuarios a deshabilitar por base de datos." TextStyle="TextStyle.Body1" />

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
        <RadzenButton Text="@(isProcessing ? "Procesando..." : "Generar Usuarios Disable")"
                      ButtonStyle="ButtonStyle.Danger"
                      Icon="@(isProcessing ? "hourglass_empty" : "sync")"
                      Click="ProcesarUsuarios"
                      Disabled="@isProcessing"
                      Size="ButtonSize.Medium" />
        @if (ultimoProceso != null)
        {
            <RadzenText TextStyle="TextStyle.Caption" Text="@($"última ejecución: {ultimoProceso.Value:dd/MM/yyyy HH:mm:ss}")" />
        }
    </RadzenStack>

    @if (isProcessing)
    {
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Style="width:300px;" />
            <RadzenText Text="Cargando datos..." TextStyle="TextStyle.Body2" />
        </RadzenStack>
    }

    <div class="rz-p-sm-12">
        <RadzenAccordion Multiple="true">
            <Items>
                @RenderAccordion("bd_siebel",   "BD Siebel",   "storage",             usersBdSiebel)
                @RenderAccordion("bd_portal",   "BD Portal",   "web",                 usersBdPortal)
                @RenderAccordion("bd_dwh_fijo", "BD DWH Fijo", "dns",                 usersBdDwhFijo)
                @RenderAccordion("bd_dwh_movil","BD DWH Móvil","storage",             usersBdDwhMovil)
                @RenderAccordion("bd_fenix",    "BD Fénix",    "whatshot",            usersBdFenix)
                @RenderAccordion("bd_open",     "BD Open",     "settings_input_component", usersBdOpen)
                @RenderAccordion("bd_sap_erp",  "BD SAP ERP",  "business",            usersBdSapErp)
                @RenderAccordion("bd_sap_grc",  "BD SAP GRC",  "security",            usersBdSapGrc)
                @RenderAccordion("bd_iam",      "BD IAM",      "groups",              usersBdIam)
                @RenderAccordion("bd_orion",    "BD Orion",    "hub",                 usersBdOrion)
                @RenderAccordion("bd_the",      "BD THE",      "cloud",               usersBdThe)
                @RenderAccordion("bd_cbs",      "BD CBS",      "grid_view",           usersBdCbs)
                @RenderAccordion("bd_cm",       "BD CM",       "settings",            usersBdCm)
            </Items>
        </RadzenAccordion>
    </div>
</RadzenStack>

@code {
    private bool isProcessing = false;
    private bool dataLoaded = false;
    private DateTime? ultimoProceso;
    private Dictionary<string, bool> processingByApp = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, string> selectedTipoCruce = new(StringComparer.OrdinalIgnoreCase);

    private IEnumerable<UsuarioDisableDto> usersBdSiebel   = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersBdPortal   = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersBdDwhFijo  = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersBdDwhMovil = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersBdFenix    = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersBdOpen     = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersBdSapErp   = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersBdSapGrc   = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersBdIam      = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersBdOrion    = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersBdThe      = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersBdCbs      = Enumerable.Empty<UsuarioDisableDto>();
    private IEnumerable<UsuarioDisableDto> usersBdCm       = Enumerable.Empty<UsuarioDisableDto>();

    private static readonly string[] _apps = {
        "bd_siebel","bd_portal","bd_dwh_fijo","bd_dwh_movil","bd_fenix","bd_open",
        "bd_sap_erp","bd_sap_grc","bd_iam","bd_orion","bd_the","bd_cbs","bd_cm"
    };

    protected override void OnInitialized()
    {
        foreach (var a in _apps)
        {
            if (!selectedTipoCruce.ContainsKey(a)) selectedTipoCruce[a] = "AMBOS";
            if (!processingByApp.ContainsKey(a))   processingByApp[a]   = false;
        }
    }

    private RenderFragment RenderAccordion(string app, string label, string icon, IEnumerable<UsuarioDisableDto> data) =>
        @<RadzenAccordionItem Text="@($"{label} - Total: {data?.Count() ?? 0}")" Icon="@icon">
            <RadzenStack Gap="0.5rem">
                <RadzenText TextStyle="TextStyle.Caption" Text="@($"Total registros: {data?.Count() ?? 0}")" />
                @RenderSeccionProcesar(app, data)
                <RadzenTabs RenderMode="TabRenderMode.Client">
                    <Tabs>
                        <RadzenTabsItem Text="Por Login">
                            <RadzenStack Gap="0.5rem">
                                <RadzenText TextStyle="TextStyle.Caption" Text="@($"Registros: {data?.Count(x => x.TipoCruce == "LOGIN") ?? 0}")" class="rz-color-success" />
                                @RenderDataGrid(data?.Where(x => x.TipoCruce == "LOGIN"))
                            </RadzenStack>
                        </RadzenTabsItem>
                        <RadzenTabsItem Text="Por Cedula">
                            <RadzenStack Gap="0.5rem">
                                <RadzenText TextStyle="TextStyle.Caption" Text="@($"Registros: {data?.Count(x => x.TipoCruce == "CEDULA") ?? 0}")" class="rz-color-info" />
                                <RadzenAlert Severity="AlertSeverity.Info" AllowClose="false" Variant="Variant.Flat" Size="AlertSize.ExtraSmall">
                                    Estos usuarios coinciden por numero de documento pero su Login no coincidía o era diferente.
                                </RadzenAlert>
                                @RenderDataGrid(data?.Where(x => x.TipoCruce == "CEDULA"))
                            </RadzenStack>
                        </RadzenTabsItem>
                    </Tabs>
                </RadzenTabs>
            </RadzenStack>
        </RadzenAccordionItem>;

    private RenderFragment RenderSeccionProcesar(string app, IEnumerable<UsuarioDisableDto> data) => builder =>
    {
        int seq = 0;
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "style", "background:#1a1d27; border:1px solid #2d3148; border-radius:8px; padding:14px 16px; margin-bottom:12px;");

        builder.OpenComponent<RadzenStack>(seq++);
        builder.AddAttribute(seq++, "Orientation", Orientation.Horizontal);
        builder.AddAttribute(seq++, "AlignItems", AlignItems.Center);
        builder.AddAttribute(seq++, "Gap", "1rem");
        builder.AddAttribute(seq++, "ChildContent", (RenderFragment)((sb) =>
        {
            int s = 0;
            sb.OpenComponent<RadzenText>(s++);
            sb.AddAttribute(s++, "Text", "Seleccionar para Procesar:");
            sb.AddAttribute(s++, "TextStyle", TextStyle.Subtitle2);
            sb.AddAttribute(s++, "TagName", TagName.H6);
            sb.CloseComponent();

            var items = new[]
            {
                new { Key = "AMBOS", Text = "Ambos" },
                new { Key = "LOGIN", Text = "Login" },
                new { Key = "CEDULA", Text = "Cedula" }
            };
            sb.OpenComponent<RadzenDropDown<string>>(s++);
            sb.AddAttribute(s++, "Data", items);
            sb.AddAttribute(s++, "TextProperty", "Text");
            sb.AddAttribute(s++, "ValueProperty", "Key");
            sb.AddAttribute(s++, "Value", selectedTipoCruce.GetValueOrDefault(app, "AMBOS"));
            sb.AddAttribute(s++, "ValueChanged", EventCallback.Factory.Create<string>(this, (v) => { selectedTipoCruce[app] = v; StateHasChanged(); }));
            sb.AddAttribute(s++, "Style", "width:200px;");
            sb.AddAttribute(s++, "Disabled", !dataLoaded);
            sb.CloseComponent();

            sb.OpenComponent<RadzenButton>(s++);
            sb.AddAttribute(s++, "Text", processingByApp.GetValueOrDefault(app, false) ? "Procesando..." : "Procesar OC");
            sb.AddAttribute(s++, "ButtonStyle", ButtonStyle.Success);
            sb.AddAttribute(s++, "Icon", processingByApp.GetValueOrDefault(app, false) ? "hourglass_empty" : "playlist_add_check");
            sb.AddAttribute(s++, "Size", ButtonSize.Small);
            sb.AddAttribute(s++, "Disabled", processingByApp.GetValueOrDefault(app, false) || !dataLoaded);
            sb.AddAttribute(s++, "Click", EventCallback.Factory.Create<MouseEventArgs>(this, async () => await ProcesarOC(app)));
            sb.CloseComponent();

            sb.OpenComponent<RadzenText>(s++);
            sb.AddAttribute(s++, "Text", "Se seleccionaran los 50 Max registros mas recientes por fecha de retiro");
            sb.AddAttribute(s++, "TextStyle", TextStyle.Caption);
            sb.AddAttribute(s++, "class", "rz-color-info-dark");
            sb.CloseComponent();

            if (!dataLoaded)
            {
                sb.OpenComponent<RadzenText>(s++);
                sb.AddAttribute(s++, "Text", "Ejecute 'Generar Usuarios Disable' para habilitar el procesamiento.");
                sb.AddAttribute(s++, "TextStyle", TextStyle.Caption);
                sb.AddAttribute(s++, "class", "rz-color-warning");
                sb.CloseComponent();
            }
        }));
        builder.CloseComponent();
        builder.CloseElement();
    };

    private RenderFragment RenderDataGrid(IEnumerable<UsuarioDisableDto> data) => builder =>
    {
        if (data == null) data = Enumerable.Empty<UsuarioDisableDto>();
        int seq = 0;
        builder.OpenComponent<RadzenDataGrid<UsuarioDisableDto>>(seq++);
        builder.AddAttribute(seq++, "Data", data);
        builder.AddAttribute(seq++, "AllowFiltering", true);
        builder.AddAttribute(seq++, "AllowSorting", true);
        builder.AddAttribute(seq++, "AllowPaging", true);
        builder.AddAttribute(seq++, "PageSize", 10);
        builder.AddAttribute(seq++, "AllowColumnResize", true);
        builder.AddAttribute(seq++, "Density", Density.Compact);
        builder.AddAttribute(seq++, "EmptyText", "No hay registros para mostrar");
        builder.AddAttribute(seq++, "FilterCaseSensitivity", FilterCaseSensitivity.CaseInsensitive);
        builder.AddAttribute(seq++, "Columns", (RenderFragment)((cb) =>
        {
            int c = 0;
            void Col(string prop, string title, string width = null, string fmt = null)
            {
                cb.OpenComponent<RadzenDataGridColumn<UsuarioDisableDto>>(c++);
                cb.AddAttribute(c++, "Property", prop);
                cb.AddAttribute(c++, "Title", title);
                if (width != null) cb.AddAttribute(c++, "Width", width);
                if (fmt   != null) cb.AddAttribute(c++, "FormatString", fmt);
                cb.AddAttribute(c++, "Filterable", true);
                cb.AddAttribute(c++, "Sortable", true);
                cb.CloseComponent();
            }
            Col("CedulaApp",        "Cédula App",         "120px");
            Col("CedulaConsolidado","Cédula Consolidado", "120px");
            Col("LoginApp",         "Login App",          "150px");
            Col("LoginConsolidado", "Login Consolidado",  "150px");
            Col("NombreConsolidado","Nombre",             "200px");
            Col("EstadoApp",        "Estado App",         "150px");
            Col("EstadoConsolidado","Estado Consolidado", "120px");
            Col("FechaRetiro",      "Fecha Retiro",       "120px", "{0:dd/MM/yyyy}");
            Col("TipoCruce",        "Tipo Cruce",         "100px");
        }));
        builder.CloseComponent();
    };

    private async Task ProcesarUsuarios()
    {
        isProcessing = true;
        StateHasChanged();
        await Task.Delay(50);

        try
        {
            usersBdSiebel   = (await UserDisableService.UsuariosBdSiebelDisable())   ?? Enumerable.Empty<UsuarioDisableDto>();
            usersBdPortal   = (await UserDisableService.UsuariosBdPortalDisable())   ?? Enumerable.Empty<UsuarioDisableDto>();
            usersBdDwhFijo  = (await UserDisableService.UsuariosBdDwhFijoDisable())  ?? Enumerable.Empty<UsuarioDisableDto>();
            usersBdDwhMovil = (await UserDisableService.UsuariosBdDwhMovilDisable()) ?? Enumerable.Empty<UsuarioDisableDto>();
            usersBdFenix    = (await UserDisableService.UsuariosBdFenixDisable())    ?? Enumerable.Empty<UsuarioDisableDto>();
            usersBdOpen     = (await UserDisableService.UsuariosBdOpenDisable())     ?? Enumerable.Empty<UsuarioDisableDto>();
            usersBdSapErp   = (await UserDisableService.UsuariosBdSapErpDisable())   ?? Enumerable.Empty<UsuarioDisableDto>();
            usersBdSapGrc   = (await UserDisableService.UsuariosBdSapGrcDisable())   ?? Enumerable.Empty<UsuarioDisableDto>();
            usersBdIam      = (await UserDisableService.UsuariosBdIamDisable())      ?? Enumerable.Empty<UsuarioDisableDto>();
            usersBdOrion    = (await UserDisableService.UsuariosBdOrionDisable())    ?? Enumerable.Empty<UsuarioDisableDto>();
            usersBdThe      = (await UserDisableService.UsuariosBdTheDisable())      ?? Enumerable.Empty<UsuarioDisableDto>();
            usersBdCbs      = (await UserDisableService.UsuariosBdCbsDisable())      ?? Enumerable.Empty<UsuarioDisableDto>();
            usersBdCm       = (await UserDisableService.UsuariosBdCmDisable())       ?? Enumerable.Empty<UsuarioDisableDto>();

            ultimoProceso = DateTime.Now;
            dataLoaded = true;

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary  = "Proceso Completado",
                Detail   = "Se han generado los cruces de usuarios BD para deshabilitar.",
                Duration = 4000
            });
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary  = "Error",
                Detail   = $"Error durante el cruce: {ex.Message}",
                Duration = 8000
            });
        }
        finally { isProcessing = false; StateHasChanged(); }
    }

    private async Task ProcesarOC(string app)
    {
        if (string.IsNullOrWhiteSpace(app)) return;
        processingByApp[app] = true;
        StateHasChanged();

        try
        {
            var tipo = selectedTipoCruce.GetValueOrDefault(app, "AMBOS");
            var ok = await DisplayService.ProcesarUsuariosSeleccionadosBD(app, tipo, 50);

            if (ok)
            {
                await RefreshApp(app);
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary  = "Procesado",
                    Detail   = $"Se procesaron los usuarios para {app} (tipo: {tipo}).",
                    Duration = 4000
                });
            }
            else
            {
                await RefreshApp(app);
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Info,
                    Summary  = "Sin Registros",
                    Detail   = $"No se encontraron usuarios para procesar en {app}.",
                    Duration = 3000
                });
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary  = "Error",
                Detail   = $"Error procesando {app}: {ex.Message}",
                Duration = 8000
            });
        }
        finally { processingByApp[app] = false; StateHasChanged(); }
    }

    private async Task RefreshApp(string app)
    {
        switch (app.ToLower())
        {
            case "bd_siebel":   usersBdSiebel   = (await UserDisableService.UsuariosBdSiebelDisable())   ?? Enumerable.Empty<UsuarioDisableDto>(); break;
            case "bd_portal":   usersBdPortal   = (await UserDisableService.UsuariosBdPortalDisable())   ?? Enumerable.Empty<UsuarioDisableDto>(); break;
            case "bd_dwh_fijo": usersBdDwhFijo  = (await UserDisableService.UsuariosBdDwhFijoDisable())  ?? Enumerable.Empty<UsuarioDisableDto>(); break;
            case "bd_dwh_movil":usersBdDwhMovil = (await UserDisableService.UsuariosBdDwhMovilDisable()) ?? Enumerable.Empty<UsuarioDisableDto>(); break;
            case "bd_fenix":    usersBdFenix    = (await UserDisableService.UsuariosBdFenixDisable())    ?? Enumerable.Empty<UsuarioDisableDto>(); break;
            case "bd_open":     usersBdOpen     = (await UserDisableService.UsuariosBdOpenDisable())     ?? Enumerable.Empty<UsuarioDisableDto>(); break;
            case "bd_sap_erp":  usersBdSapErp   = (await UserDisableService.UsuariosBdSapErpDisable())   ?? Enumerable.Empty<UsuarioDisableDto>(); break;
            case "bd_sap_grc":  usersBdSapGrc   = (await UserDisableService.UsuariosBdSapGrcDisable())   ?? Enumerable.Empty<UsuarioDisableDto>(); break;
            case "bd_iam":      usersBdIam      = (await UserDisableService.UsuariosBdIamDisable())      ?? Enumerable.Empty<UsuarioDisableDto>(); break;
            case "bd_orion":    usersBdOrion    = (await UserDisableService.UsuariosBdOrionDisable())    ?? Enumerable.Empty<UsuarioDisableDto>(); break;
            case "bd_the":      usersBdThe      = (await UserDisableService.UsuariosBdTheDisable())      ?? Enumerable.Empty<UsuarioDisableDto>(); break;
            case "bd_cbs":      usersBdCbs      = (await UserDisableService.UsuariosBdCbsDisable())      ?? Enumerable.Empty<UsuarioDisableDto>(); break;
            case "bd_cm":       usersBdCm       = (await UserDisableService.UsuariosBdCmDisable())       ?? Enumerable.Empty<UsuarioDisableDto>(); break;
        }
        StateHasChanged();
    }
}
