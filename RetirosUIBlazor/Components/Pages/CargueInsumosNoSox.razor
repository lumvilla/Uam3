@page "/nosox/cargue-insumos"
@using Data.Interfaces.CapaApp.Uam3.IAppInsumosRobot
@using Data.Interfaces.CapaApp.Uam3.IDataInsumosRobot
@using Microsoft.AspNetCore.Components.Forms
@inject IAppInsumosRobot RobotService
@inject IDataInsumosRobot DatosRepo
@inject NotificationService NotificationService

<PageTitle>Cargue Insumos — No Sox</PageTitle>

<style>
    .ci-title { font-size:22px; font-weight:800; color:#fff; margin-bottom:4px; }
    .ci-breadcrumb { font-size:12px; color:#6b7280; margin-bottom:20px; }
    .ci-alert { background:rgba(245,158,11,.08); border:1px solid rgba(245,158,11,.25); border-left:4px solid #f59e0b; border-radius:10px; padding:14px 16px; display:flex; gap:12px; align-items:flex-start; margin-bottom:20px; }
    .ci-alert-title { font-size:13px; font-weight:700; color:#f59e0b; margin-bottom:3px; }
    .ci-alert-text { font-size:13px; color:#d1a84a; line-height:1.5; }
    .ci-section-label { font-size:11px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:1px; padding:12px 0 6px; border-bottom:1px solid #2d3148; margin-bottom:10px; }
    .ci-manual-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:20px; }
    .ci-upload-card { background:#1a1d27; border:1px solid #2d3148; border-radius:10px; overflow:hidden; }
    .ci-upload-card-hdr { padding:10px 14px; display:flex; align-items:center; gap:8px; }
    .ci-upload-card-icon { width:26px; height:26px; border-radius:7px; display:flex; align-items:center; justify-content:center; font-size:13px; background:rgba(99,102,241,.12); flex-shrink:0; }
    .ci-upload-card-name { font-size:13px; font-weight:600; color:#e2e8f0; flex:1; }
    .ci-upload-body { padding:8px 14px 10px; border-top:1px solid #2d3148; }
    .ci-file-input { display:none; }
    .ci-file-label { background:#252840; color:#9ca3af; border:1px solid #2d3148; padding:6px 12px; border-radius:7px; font-size:11px; font-weight:500; cursor:pointer; display:inline-flex; align-items:center; gap:5px; }
    .ci-file-label:hover { border-color:#6366f1; color:#a5b4fc; }
    .ci-file-pill { background:rgba(99,102,241,.1); border:1px solid rgba(99,102,241,.25); border-radius:6px; padding:4px 10px; font-size:11px; color:#a5b4fc; display:flex; align-items:center; gap:5px; margin-bottom:5px; }
    .ci-upload-actions { display:flex; gap:6px; margin-top:5px; }
    .ci-btn-p { background:linear-gradient(135deg,#6366f1,#8b5cf6); color:#fff; border:none; padding:6px 12px; border-radius:7px; font-size:11px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:4px; }
    .ci-btn-p:disabled { opacity:.4; cursor:not-allowed; }
    .ci-btn-g { background:#252840; color:#9ca3af; border:1px solid #2d3148; padding:6px 10px; border-radius:7px; font-size:11px; cursor:pointer; }
    .ci-prog { background:#13151f; border:1px solid #2d3148; border-radius:7px; padding:7px 10px; display:flex; align-items:center; gap:8px; }
    .ci-spin { width:14px; height:14px; border:2px solid #2d3148; border-top-color:#6366f1; border-radius:50%; animation:spin .7s linear infinite; }
    @@keyframes spin { to { transform:rotate(360deg); } }
</style>

<div class="ci-title">Gestión de Insumos — Retiros No Sox</div>
<div class="ci-breadcrumb">Retiros No Sox / Cargue de Insumos</div>

<div class="ci-alert">
    <span style="font-size:18px;flex-shrink:0;">📋</span>
    <div>
        <div class="ci-alert-title">Cargue Manual de Insumos No Sox</div>
        <div class="ci-alert-text">
            <strong>Grupo A</strong> (GTC, Open Edatel, Open ETP, OSM, MSS, Tigo, Viafirma): columnas <strong>LOGIN, ESTADO</strong><br/>
            <strong>Grupo B</strong> (MAE): columnas <strong>USER_NAME, DISABLE_ACCOUNT</strong><br/>
            <strong>Service Desk</strong>: columnas <strong>LOGIN, ESTADO</strong>
        </div>
    </div>
</div>

@* Grupo A *@
<div class="ci-section-label">Grupo A — ESTADO IN ('OPEN','EXPIRED','EXPIRED(GRACE)')</div>
<div class="ci-manual-grid">
    @foreach (var s in _grupoA) { @RenderCard(s.Key, s.Value) }
</div>

@* Grupo B *@
<div class="ci-section-label">Grupo B — DISABLE_ACCOUNT = 'Enabled'</div>
<div class="ci-manual-grid">
    @foreach (var s in _grupoB) { @RenderCard(s.Key, s.Value) }
</div>

@* Grupo C *@
<div class="ci-section-label">Service Desk — ESTADO = 0</div>
<div class="ci-manual-grid">
    @foreach (var s in _grupoC) { @RenderCard(s.Key, s.Value) }
</div>

@code {
    private static readonly Dictionary<string, string> _grupoA = new()
    {
        { "nosox_gtc",         "GTC"         }, { "nosox_open_edatel", "Open Edatel" },
        { "nosox_open_etp",    "Open ETP"    }, { "nosox_osm",         "OSM"         },
        { "nosox_mss",         "MSS"         }, { "nosox_tigo_gestion","Tigo Gestión"},
        { "nosox_viafirma",    "Viafirma"    }
    };

    private static readonly Dictionary<string, string> _grupoB = new()
    {
        { "nosox_maebog1", "MAE BOG1" }, { "nosox_maebog2", "MAE BOG2" },
        { "nosox_maebaq",  "MAE BAQ"  }, { "nosox_maecore", "MAE CORE" }
    };

    private static readonly Dictionary<string, string> _grupoC = new()
    {
        { "nosox_service_desk", "Service Desk" }
    };

    private static Dictionary<string, string> _todosSistemas => _grupoA
        .Concat(_grupoB).Concat(_grupoC).ToDictionary(k => k.Key, v => v.Value);

    private class ManualUploadState
    {
        public MemoryStream? Data { get; set; }
        public string? FileName { get; set; }
        public bool IsProcessing { get; set; }
        public bool IsReading { get; set; }
    }

    private Dictionary<string, ManualUploadState> _estadoManual = new();
    private Dictionary<string, int> _counts = new();

    protected override async Task OnInitializedAsync()
    {
        foreach (var k in _todosSistemas.Keys)
            _estadoManual[k] = new ManualUploadState();
        await CargarCounts();
    }

    private async Task CargarCounts()
    {
        await Task.Run(() =>
        {
            foreach (var k in _todosSistemas.Keys)
            {
                try { _counts[k] = DatosRepo.ObtenerDatosPaginados(k, 0, 1, null, null).TotalRegistros; }
                catch { _counts[k] = -1; }
            }
        });
        StateHasChanged();
    }

    private RenderFragment RenderCard(string key, string nombre) => __builder =>
    {
        var estado  = _estadoManual.GetValueOrDefault(key, new ManualUploadState());
        var inputId = $"file-nosox-{key}";
        var cnt     = _counts.GetValueOrDefault(key, -1);

        __builder.OpenElement(0, "div");
        __builder.AddAttribute(1, "class", "ci-upload-card");

        // Header
        __builder.OpenElement(2, "div");
        __builder.AddAttribute(3, "class", "ci-upload-card-hdr");
        __builder.AddMarkupContent(4, $"<div class='ci-upload-card-icon'>⚙️</div><div class='ci-upload-card-name'>{nombre}</div>");
        if (cnt > 0) __builder.AddMarkupContent(5, $"<span style='background:rgba(34,197,94,.12);color:#22c55e;font-size:11px;padding:2px 8px;border-radius:20px;font-weight:700;border:1px solid rgba(34,197,94,.2);'>✓ {cnt:N0}</span>");
        else if (cnt == 0) __builder.AddMarkupContent(5, "<span style='background:rgba(239,68,68,.12);color:#ef4444;font-size:11px;padding:2px 8px;border-radius:20px;font-weight:700;border:1px solid rgba(239,68,68,.2);'>Sin datos</span>");
        __builder.CloseElement();

        // Body
        __builder.OpenElement(6, "div");
        __builder.AddAttribute(7, "class", "ci-upload-body");

        if (estado.IsReading)
        {
            __builder.AddMarkupContent(8, "<div class='ci-prog'><div class='ci-spin'></div><span style='font-size:11px;color:#9ca3af;'>Leyendo...</span></div>");
        }
        else if (estado.Data == null)
        {
            __builder.OpenComponent<InputFile>(9);
            __builder.AddAttribute(10, "id", inputId);
            __builder.AddAttribute(11, "accept", ".xlsx");
            __builder.AddAttribute(12, "class", "ci-file-input");
            __builder.AddAttribute(13, "OnChange", EventCallback.Factory.Create<InputFileChangeEventArgs>(this, e => OnFileChange(e, key)));
            __builder.CloseComponent();
            __builder.AddMarkupContent(14, $"<label for='{inputId}' class='ci-file-label'>📁 Seleccionar archivo</label>");
        }
        else
        {
            __builder.AddMarkupContent(15, $"<div class='ci-file-pill'>📄 {estado.FileName}</div>");
            if (estado.IsProcessing)
            {
                __builder.AddMarkupContent(16, "<div class='ci-prog'><div class='ci-spin'></div><span style='font-size:11px;color:#9ca3af;'>Cargando...</span></div>");
            }
            else
            {
                __builder.OpenElement(17, "div");
                __builder.AddAttribute(18, "class", "ci-upload-actions");

                __builder.OpenElement(19, "button");
                __builder.AddAttribute(20, "class", "ci-btn-p");
                __builder.AddAttribute(21, "onclick", EventCallback.Factory.Create(this, () => CargarArchivo(key)));
                __builder.AddMarkupContent(22, "☁️ Cargar");
                __builder.CloseElement();

                __builder.OpenElement(23, "button");
                __builder.AddAttribute(24, "class", "ci-btn-g");
                __builder.AddAttribute(25, "onclick", EventCallback.Factory.Create(this, () => Limpiar(key)));
                __builder.AddMarkupContent(26, "✕");
                __builder.CloseElement();

                __builder.CloseElement();
            }
        }

        __builder.CloseElement();
        __builder.CloseElement();
    };

    private async Task OnFileChange(InputFileChangeEventArgs e, string key)
    {
        var file = e.File;
        if (file == null) return;
        _estadoManual[key].FileName = file.Name;
        _estadoManual[key].IsReading = true;
        _estadoManual[key].Data = null;
        StateHasChanged();
        try
        {
            var ms = new MemoryStream();
            await using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            await stream.CopyToAsync(ms);
            ms.Position = 0;
            _estadoManual[key].Data = ms;
        }
        catch (Exception ex)
        {
            _estadoManual[key].Data = null;
            _estadoManual[key].FileName = null;
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error al leer", Detail = ex.Message, Duration = 5000 });
        }
        _estadoManual[key].IsReading = false;
        StateHasChanged();
    }

    private async Task CargarArchivo(string key)
    {
        var estado = _estadoManual[key];
        if (estado.Data == null) return;
        estado.IsProcessing = true;
        StateHasChanged();
        try
        {
            estado.Data.Position = 0;
            await RobotService.ImportarArchivoManual(estado.Data, estado.FileName!, key);
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Cargue Exitoso", Detail = $"{_todosSistemas[key]} cargado en '{key}'.", Duration = 4000 });
            _estadoManual[key] = new ManualUploadState();
            try { _counts[key] = DatosRepo.ObtenerDatosPaginados(key, 0, 1, null, null).TotalRegistros; } catch { }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error al cargar", Detail = ex.Message, Duration = 6000 });
            estado.IsProcessing = false;
        }
        StateHasChanged();
    }

    private void Limpiar(string key) { _estadoManual[key] = new ManualUploadState(); StateHasChanged(); }
}
