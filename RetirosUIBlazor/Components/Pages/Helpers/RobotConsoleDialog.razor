@using Data.Interfaces.CapaApp.Uam3.IAppInsumosRobot
@using Radzen
@inject IAppInsumosRobot RobotService
@inject DialogService DialogService
@inject IJSRuntime JSRuntime

<RadzenStack Orientation="Orientation.Vertical" Gap="0" Style="height: 100%; overflow: hidden;">

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" Style="padding-bottom: 1rem; border-bottom: 1px solid #e0e0e0;">
        @if (estaEjecutando)
        {
            <RadzenProgressBarCircular ShowValue="false" Mode="Radzen.ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
           
            <RadzenText TextStyle="TextStyle.Subtitle1" TagName="TagName.H3" Style="margin: 0; color: #004e87;">
                Ejecutando proceso de carga...
            </RadzenText>
        }
        else
        {
            <RadzenIcon Icon="check_circle" IconColor="@Colors.Success" />
            <RadzenText TextStyle="TextStyle.Subtitle1" TagName="TagName.H3" Style="margin: 0; color: green;">
                Proceso Finalizado
            </RadzenText>
        }
    </RadzenStack>

    <div id="scrollContainer" style="flex: 1; overflow-y: auto; padding: 1rem; background-color: #f9f9f9; border-radius: 4px;">
        <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">
            @foreach (var item in logsProcesados)
            {
                <RadzenCard Variant="Variant.Flat" Style="@ObtenerEstiloTarjeta(item.Tipo)">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Start" Gap="0.5rem">
                        <RadzenIcon Icon="@item.Icono" IconColor="@item.Color" Style="font-size: 1.2rem; margin-top: 2px;" />
                        <RadzenStack Gap="0">
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: #888;">@item.Hora</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" Style="@($"color: {item.ColorTexto}; font-weight: 500;")">
                                @item.Mensaje
                            </RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            }
        </RadzenStack>
    </div>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Style="padding-top: 1rem; border-top: 1px solid #e0e0e0;">
        <RadzenButton Text="@(estaEjecutando ? "Procesando..." : "Cerrar Ventana")"
                      Click="@(() => DialogService.Close(true))"
                      ButtonStyle="@(estaEjecutando ? ButtonStyle.Base : ButtonStyle.Primary)"
                      Disabled="@estaEjecutando" />
    </RadzenStack>

</RadzenStack>

@code {
    // Clase interna para dar formato
    private class LogItem
    {
        public string Mensaje { get; set; } = "";
        public string Hora { get; set; } = "";
        public string Icono { get; set; } = "info";
        public string Color { get; set; } = Colors.Info;
        public string ColorTexto { get; set; } = "#333";
        public string Tipo { get; set; } = "Info"; // Info, Error, Success
    }

    private List<LogItem> logsProcesados = new List<LogItem>();
    private bool estaEjecutando = true;

    protected override async Task OnInitializedAsync()
    {
        await Task.Run(() =>
        {
            try
            {
                RobotService.EjecutarCargaRobot((mensajeRaw) =>
                {
                    InvokeAsync(() => ProcesarMensaje(mensajeRaw));
                });
            }
            catch (Exception ex)
            {
                InvokeAsync(() => ProcesarMensaje($"[FATAL] {ex.Message}"));
            }
            finally
            {
                estaEjecutando = false;
                InvokeAsync(StateHasChanged);
            }
        });
    }

    // Lógica para embellecer el mensaje según palabras clave
    private void ProcesarMensaje(string mensaje)
    {
        var item = new LogItem
        {
            Mensaje = mensaje,
            Hora = DateTime.Now.ToString("hh:mm:ss tt")
        };

        if (mensaje.Contains("ERROR") || mensaje.Contains("FATAL") || mensaje.Contains("Exception"))
        {
            item.Icono = "error";
            item.Color = Colors.Danger;
            item.ColorTexto = "#d32f2f"; // Rojo oscuro
            item.Tipo = "Error";
        }
        else if (mensaje.Contains("OK") || mensaje.Contains("Finalizado") || mensaje.Contains("Exito"))
        {
            item.Icono = "check_circle";
            item.Color = Colors.Success;
            item.ColorTexto = "#1b5e20"; // Verde oscuro
            item.Tipo = "Success";
        }
        else if (mensaje.Contains("PROCESANDO") || mensaje.Contains("INICIANDO"))
        {
            item.Icono = "autorenew"; // Icono de girar
            item.Color = Colors.Primary;
            item.Tipo = "Proceso";
        }
        else if (mensaje.Contains("SKIP") || mensaje.Contains("---"))
        {
            item.Icono = "horizontal_rule";
            item.Color = Colors.InfoLight;
            item.ColorTexto = "#999";
        }

        logsProcesados.Add(item);
        StateHasChanged();

        // Auto-scroll simple con JS (opcional, si tienes JS interop)
        JSRuntime.InvokeVoidAsync("eval", "var elem = document.getElementById('scrollContainer'); elem.scrollTop = elem.scrollHeight");
    }

    private string ObtenerEstiloTarjeta(string tipo)
    {
        return tipo switch
        {
            "Error" => "background-color: #fdecea; border-left: 4px solid #d32f2f; padding: 0.5rem;",
            "Success" => "background-color: #e8f5e9; border-left: 4px solid #2e7d32; padding: 0.5rem;",
            _ => "background-color: white; border-bottom: 1px solid #f0f0f0; padding: 0.5rem;"
        };
    }
}