@rendermode InteractiveServer
@inherits LayoutComponentBase
@using Radzen
@using Radzen.Blazor
@inject NavigationManager Nav

<RadzenLayout Style="min-height:100vh; background:#0f1117;">

    <!-- ══ HEADER ══ -->
    <RadzenHeader Style="background:#1a1d27; border-bottom:1px solid #2d3148; box-shadow:0 2px 8px rgba(0,0,0,.5); z-index:1000;">
        <div style="display:flex;align-items:center;gap:12px;padding:0 16px;height:60px;">
            <button @onclick="ToggleSidebar"
                    style="background:none;border:none;cursor:pointer;color:#6b7280;font-size:20px;padding:4px;border-radius:6px;display:flex;align-items:center;">
                ☰
            </button>
            <div style="width:40px;height:40px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <img src="logo_tigo.png"
                     alt="Logo Tigo"
                     style="width:100%;height:100%;object-fit:contain;">
            </div>

            <div>
                <div style="font-size:16px;font-weight:700;color:#fff;line-height:1.2;">Control de Retiros</div>
                <div style="font-size:11px;color:#6366f1;font-weight:500;">Sistema de Gestión</div>
            </div>
            <div style="margin-left:auto;display:flex;align-items:center;gap:10px;">
                <div style="background:#13151f;border:1px solid #2d3148;border-radius:20px;padding:6px 14px;font-size:12px;color:#9ca3af;display:flex;align-items:center;gap:6px;">
                    <span style="width:7px;height:7px;border-radius:50%;background:#22c55e;display:inline-block;flex-shrink:0;"></span>
                    BD Conectada
                </div>
                <div style="background:#13151f;border:1px solid #2d3148;border-radius:20px;padding:6px 14px;font-size:12px;color:#9ca3af;">
                    📅 @DateTime.Now.ToString("dd/MM/yyyy")
                </div>
            </div>
        </div>
    </RadzenHeader>

    <!-- ══ SIDEBAR ══ -->
    <RadzenSidebar Style="@SidebarStyle">
        <div style="display:flex;flex-direction:column;height:100%;overflow:hidden;">

            <!-- NAV SCROLL AREA -->
            <div style="flex:1;overflow-y:auto;padding:12px 8px 8px;">

                @* INSUMOS *@
                <div class="nav-section-label">Insumos</div>
                @NavParent("folder_open", "Cargue de Insumos", "insumos")
                @if (expanded["insumos"])
                {
                    <div class="nav-children">
                        @NavChild("upload", "DA / Retiros / Terceros", "/cargue-retiros")
                    </div>
                }

                @* UAM3 *@
                <div class="nav-section-label">UAM3</div>
                @NavParent("layers", "Capa Aplicación", "capaapp")
                @if (expanded["capaapp"])
                {
                    <div class="nav-children">
                        @NavChild("cloud_upload", "Cargue de Insumos", "/uam3/cargue-insumos-app")
                        @NavChild("person_remove", "Usuarios a Deshabilitar", "/uam3/user-disable")
                        @NavChild("support_agent", "Service Desk", "/uam3/ServicesDesk/retiros-user")
                        @NavChild("assessment", "Reportes", "/uam3/reportes")
                    </div>
                }
                @NavParent("storage", "Capa Base de Datos", "capabd")
                @if (expanded["capabd"])
                {
                    <div class="nav-children">
                        @NavChild("cloud_upload", "Cargue de Insumos", "/uam3/cargue-insumos-bd")
                        @NavChild("person_remove", "Usuarios a Deshabilitar", "/uam3/user-disable-Bd")
                        @NavChild("support_agent", "Service Desk", "/uam3/service-desk")
                        @NavChild("assessment", "Reportes", "/uam3/reportes-bd")
                    </div>
                }

                @* RETIROS NO SOX *@
                <div class="nav-section-label">Retiros No Sox</div>
                @NavParent("group_remove", "Retiros No Sox", "nosox")
                @if (expanded["nosox"])
                {
                    <div class="nav-children">
                        @NavChild("cloud_upload", "Cargue de Insumos", "/nosox/cargue-insumos")
                        @NavChild("person_remove", "Usuarios a Deshabilitar", "/nosox/user-disable")
                        @NavParentSub("support_agent", "Service Desk", "nosoxsd")
                        @if (expanded["nosoxsd"])
                        {
                            <div class="nav-children" style="margin-left:12px;">
                                @NavChild("add_task", "Generar OC Retiros", "/nosox/sd/realizar-oc")
                                @NavChild("fact_check", "Validar Estado OC", "/nosox/sd/consultar-estado")
                            </div>
                        }
                        @NavChild("assessment", "Reportes", "/nosox/reportes")
                    </div>
                }

                @* HERRAMIENTAS *@
                <div class="nav-section-label">Herramientas</div>
                @NavChild("terminal", "Ejecutar SQL", "/sql-console")
                @NavChild("help", "Guía de Usuario", "/guia")

            </div>

            <!-- FOOTER -->
            <div style="border-top:1px solid #2d3148;padding:14px 16px;background:#1a1d27;flex-shrink:0;">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:34px;height:34px;background:linear-gradient(135deg,#0B3A82,#0B3A82);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff;flex-shrink:0;">TG</div>
                    <div>
                        <div style="font-size:13px;font-weight:600;color:#e2e8f0;">Control Retiros</div>
                        <div style="font-size:11px;color:#0B3A82;">Tigo Telecomunicaciones</div>
                    </div>
                </div>
            </div>
        </div>
    </RadzenSidebar>

    <!-- ══ BODY ══ -->
    <RadzenBody>
        <div style="background:#0f1117;min-height:calc(100vh - 60px);padding:24px;">
            @Body
        </div>
    </RadzenBody>

</RadzenLayout>

<RadzenDialog />
<RadzenNotification />
<RadzenContextMenu />
<RadzenTooltip />

<style>
    /* ── SECTION LABELS ── */
    .nav-section-label {
        padding: 16px 12px 5px;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 1.4px;
        color: #3d4166;
        font-weight: 700;
    }

    /* ── NAV ITEMS ── */
    .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        margin: 1px 0;
        border-radius: 8px;
        cursor: pointer;
        font-size: 13px;
        color: #9ca3af;
        transition: all 0.15s ease;
        text-decoration: none;
        user-select: none;
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
    }

        .nav-item:hover {
            background: #252840;
            color: #e2e8f0;
        }

        .nav-item.active {
            background: linear-gradient(135deg,#6366f1,#8b5cf6);
            color: #fff !important;
        }

        .nav-item .material-icons {
            font-size: 18px;
            color: #4b5563;
            flex-shrink: 0;
            transition: color 0.15s;
        }

        .nav-item:hover .material-icons {
            color: #ffffff;
        }

        .nav-item.active .material-icons {
            color: #fff;
        }

    .nav-item-chevron {
        margin-left: auto;
        font-size: 14px;
        color: #FFFFFF;
        transition: transform 0.2s;
    }

        .nav-item-chevron.open {
            transform: rotate(180deg);
        }

    /* ── CHILDREN ── */
    .nav-children {
        margin-left: 16px;
        border-left: 2px solid #ffffff;
        padding-left: 4px;
    }

        .nav-children .nav-item {
            font-size: 12px;
            padding: 7px 10px;
            color: #6b7280;
        }

            .nav-children .nav-item:hover {
                color: #e2e8f0;
                background: #1e2035;
            }

            .nav-children .nav-item.active {
                background: rgba(99,102,241,.2);
                color: #a5b4fc;
            }

            .nav-children .nav-item .material-icons {
                font-size: 16px;
            }

    /* ── RADZEN OVERRIDES ── */
    .rz-layout, .rz-body {
        background: #0f1117 !important;
    }

    .rz-sidebar {
        background: #1a1d27 !important;
        border-right: 1px solid #2d3148 !important;
    }

    .rz-header {
        background: #1a1d27 !important;
    }

    .rz-footer {
        display: none !important;
    }

    .rz-card {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .rz-sidebar .rz-panel-menu,
    .rz-sidebar .rz-panel-menu-item-wrapper,
    .rz-sidebar .rz-panel-menu-item-link {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
    }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar {
        width: 5px;
        height: 5px;
    }

    ::-webkit-scrollbar-track {
        background: transparent;
    }

    ::-webkit-scrollbar-thumb {
        background: #2d3148;
        border-radius: 3px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: #3d4166;
        }
</style>

@code {
    bool sidebarExpanded = true;

    string SidebarStyle => sidebarExpanded
        ? "width:264px; background:#1a1d27; border-right:1px solid #2d3148; transition:width .2s ease;"
        : "width:0; overflow:hidden; background:#1a1d27; transition:width .2s ease;";

    Dictionary<string, bool> expanded = new()
    {
        ["insumos"] = true,
        ["capaapp"] = false,
        ["capabd"] = false,
        ["nosox"] = false,
        ["nosoxsd"] = false,
    };

    void ToggleSidebar() => sidebarExpanded = !sidebarExpanded;
    void Toggle(string key) => expanded[key] = !expanded[key];

    bool IsActive(string path) =>
        Nav.Uri.EndsWith(path, StringComparison.OrdinalIgnoreCase) ||
        Nav.Uri.Contains(path + "/", StringComparison.OrdinalIgnoreCase);

    // Parent nav item (expandable)
    RenderFragment NavParent(string icon, string label, string key) => __builder =>
    {
        __builder.OpenElement(0, "button");
        __builder.AddAttribute(1, "class", "nav-item");
        __builder.AddAttribute(2, "onclick", EventCallback.Factory.Create(this, () => Toggle(key)));
        __builder.AddMarkupContent(3, $"<span class='material-icons'>{icon}</span>");
        __builder.AddMarkupContent(4, $"<span style='flex:1;'>{label}</span>");
        __builder.AddMarkupContent(5, $"<span class='nav-item-chevron {(expanded[key] ? "open" : "")}'>expand_more</span>".Replace("expand_more", "▾"));
        __builder.CloseElement();
    };

    // Sub-level expandable (inside children)
    RenderFragment NavParentSub(string icon, string label, string key) => __builder =>
    {
        __builder.OpenElement(0, "button");
        __builder.AddAttribute(1, "class", "nav-item");
        __builder.AddAttribute(2, "onclick", EventCallback.Factory.Create(this, () => Toggle(key)));
        __builder.AddMarkupContent(3, $"<span class='material-icons'>{icon}</span>");
        __builder.AddMarkupContent(4, $"<span style='flex:1;'>{label}</span>");
        __builder.AddMarkupContent(5, $"<span class='nav-item-chevron {(expanded[key] ? "open" : "")}'>▾</span>");
        __builder.CloseElement();
    };

    // Leaf nav item (navigates)
    RenderFragment NavChild(string icon, string label, string path) => __builder =>
    {
        var active = IsActive(path) ? " active" : "";
        __builder.OpenElement(0, "a");
        __builder.AddAttribute(1, "class", $"nav-item{active}");
        __builder.AddAttribute(2, "href", path);
        __builder.AddMarkupContent(3, $"<span class='material-icons'>{icon}</span>");
        __builder.AddMarkupContent(4, $"<span>{label}</span>");
        __builder.CloseElement();
    };
}
